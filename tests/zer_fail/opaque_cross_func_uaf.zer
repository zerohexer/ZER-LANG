// 9b negative: use alloc_ptr result after cross-function free

struct Task { u32 id; }
Slab(Task) heap;

void destroy(*Task t) {
    heap.free_ptr(t);
}

u32 main() {
    *Task t = heap.alloc_ptr() orelse { return 1; };
    t.id = 42;
    destroy(t);
    t.id = 99;    // UAF — t freed by destroy() via cross-func summary
    return 0;
}
