// Rust pattern: Box alloc/dealloc cycle — allocate, use, free, repeat.
// ZER: Slab alloc_ptr cycle, verify no leak across iterations.

struct Node { u32 data; u32 next_id; }
Slab(Node) heap;

u32 main() {
    u32 total = 0;

    for (u32 i = 0; i < 10; i += 1) {
        ?*Node mn = heap.alloc_ptr();
        *Node n = mn orelse return;
        n.data = i * 5;
        n.next_id = i + 1;
        total += n.data;
        heap.free_ptr(n);
    }

    // 0 + 5 + 10 + 15 + 20 + 25 + 30 + 35 + 40 + 45 = 225
    if (total != 225) { return 1; }
    return 0;
}
