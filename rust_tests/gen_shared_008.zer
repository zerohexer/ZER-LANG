// Shared struct: same-statement multi-lock deadlock — compile error
// BUG-464: cross-statement is safe, same-statement is the real danger.
// EXPECTED: compile error

shared struct A { u32 x; }
shared struct B { u32 y; }
A ga;
B gb;

u32 main() {
    ga.x = gb.y;   // ERROR: accesses both A and B in one statement
    return 0;
}
