// GAP-4 (HIGH) — Function-pointer call freeing a Handle is not tracked
//
// Per docs/limitations.md ("Gap 15 reverified 2026-05-25"), indirect
// calls through a function pointer don't propagate FuncSummary
// frees_param info. The handle remains ALIVE → subsequent direct
// `heap.free(h)` is the FIRST free from the analyzer's view, but is
// actually the SECOND free.
//
// Compile-time: zercheck doesn't know `fp(h)` frees `h`.
// Runtime: `_zer_slab_free` is intentionally lenient on already-freed
// handles (no h_gen != gen[idx] trap on the free path — only on get).
// Result: double free passes both gates silently. exit=0.
//
// Compare with bare `free_handle(h); heap.free(h)` which IS caught
// via FuncSummary propagation. The difference is purely whether
// the call is direct or indirect.

struct Item { u32 value; }
Slab(Item) heap;

void free_handle(Handle(Item) h) { heap.free(h); }

i32 main() {
    Handle(Item) h = heap.alloc() orelse return;
    *(Handle(Item)) -> void fp = free_handle;
    fp(h);          // freed indirectly — not tracked
    heap.free(h);   // direct free — DOUBLE FREE, silent
    return 0;
}
