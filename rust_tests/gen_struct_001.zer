// Struct: nested struct field access and mutation

struct Inner { u32 a; u32 b; }
struct Outer { Inner in; u32 c; }

u32 main() {
    Outer o;
    o.in.a = 1;
    o.in.b = 2;
    o.c = 3;

    if (o.in.a != 1) { return 1; }
    if (o.in.b != 2) { return 2; }
    if (o.c != 3) { return 3; }

    o.in.a += o.in.b;
    if (o.in.a != 3) { return 4; }
    return 0;
}
