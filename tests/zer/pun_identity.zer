// @pun(*T, src) where source and target are the same type — identity cast
// equivalent. The emitted runtime type_id check passes (Sensor == Sensor),
// no trap. The value reads back correctly.

struct Sensor { u32 reading; u32 id; }
Slab(Sensor) sensors;

u32 main() {
    ?*Sensor ms = sensors.alloc_ptr();
    *Sensor s = ms orelse { return 1; };
    s.reading = 42;
    s.id = 7;

    // @pun *Sensor → *Sensor — identity round-trip via inline *opaque wrap
    *Sensor back = @pun(*Sensor, s);
    if (back.reading != 42) { return 2; }
    if (back.id != 7) { return 3; }

    sensors.free_ptr(s);
    return 0;
}
