// UAF: free in one if-branch, use after if (maybe_freed)
// EXPECTED: compile error

struct Widget { u32 x; }
Pool(Widget, 4) pool;

u32 main() {
    ?Handle(Widget) mh = pool.alloc();
    Handle(Widget) h = mh orelse return;
    pool.get(h).x = 5;

    bool cond = true;
    if (cond) {
        pool.free(h);
        return 0;
    }

    u32 val = pool.get(h).x;
    return val;
}
