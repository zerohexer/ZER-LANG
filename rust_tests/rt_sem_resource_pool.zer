// 6 workers share 3 resources
Semaphore(3) resources;
void use_resource(u32 id) { @sem_acquire(resources); @sem_release(resources); }
u32 main() {
    ThreadHandle t1 = spawn use_resource(1);
    ThreadHandle t2 = spawn use_resource(2);
    ThreadHandle t3 = spawn use_resource(3);
    ThreadHandle t4 = spawn use_resource(4);
    ThreadHandle t5 = spawn use_resource(5);
    ThreadHandle t6 = spawn use_resource(6);
    t1.join(); t2.join(); t3.join(); t4.join(); t5.join(); t6.join();
    return 0;
}
