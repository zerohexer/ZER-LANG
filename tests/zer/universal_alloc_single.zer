// Universal alloc — alloc(T) -> ?*T (single heap object) + free(x).
// The brainless single-object allocation surface: no Slab declaration, no
// Handle, no Arena. See docs/universal_alloc.md.
i32 puts(const *u8 s);

struct Task { u32 id; u32 value; }

u32 main() {
    *Task t = alloc(Task) orelse return;
    t.id = 7;
    t.value = 42;
    if (t.id != 7) { return 1; }
    if (t.value != 42) { return 2; }
    free(t);
    puts("universal_alloc_single: ok");
    return 0;
}
