// Regression: for-loop expression-form init was silently UNTYPED.
// Discovered 2026-05-29 via walker_default_audit.sh.
//
// Symptom (pre-fix): `for (i = 0; ...; ...)` — where init is a NODE_ASSIGN
// (expression form), not a NODE_VAR_DECL — was dispatched through check_stmt
// which had a silent default `break;`. The init was NEVER type-checked.
//
// Test: a valid expression-form init must compile (i is declared above);
// the regression is verifying the existing pattern still works after the
// dispatch was tightened to call check_expr for non-VAR_DECL inits.

u32 main() {
    u32 total = 0;
    u32 i = 0;
    for (i = 0; i < 5; i += 1) {
        total += i;
    }
    if (total != 10) { return 1; }  // 0+1+2+3+4 = 10
    return 0;
}
