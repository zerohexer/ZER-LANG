// Interior-pointer deref BEFORE free is safe: read the value through `*p`, then
// free the parent. Companion to tests/zer_fail/interior_ptr_deref_uaf.zer — proves
// the BUG-765 fix (UAF walker now runs on IR_UNOP/deref) does NOT over-reject the
// legitimate use-before-free.
struct B { u32 a; u32 b; }
Slab(B) heap;
u32 test() {
    ?*B mb = heap.alloc_ptr();
    *B b = mb orelse return;
    b.a = 7;
    *u32 p = &b.a;
    u32 val = *p;        // deref before free — safe
    heap.free_ptr(b);
    if (val != 7) { return 1; }
    return 0;
}
u32 main() { return test(); }
