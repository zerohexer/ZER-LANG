container SliceHolder(T) {
    [*]T data;
    u32 count;
}

i32 main() {
    u32[4] arr;
    arr[0] = 1;
    arr[1] = 2;
    arr[2] = 3;
    arr[3] = 4;

    SliceHolder(u32) h;
    h.data = arr;
    h.count = 4;

    u32 sum = 0;
    for (u32 i = 0; i < h.count; i += 1) {
        sum += h.data.ptr[i];
    }
    if (sum != 10) { return 1; }
    return 0;
}
