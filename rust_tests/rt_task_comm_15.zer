// Rust source: tests/ui/threads-sendsync/task-comm-15.rs
// Safety scenario: thread sends 10 messages, receiver may exit early (after 1).
// Verifies graceful handling when receiver disconnects before producer finishes.
// The safety property: producer must not crash/hang if receiver is gone.
// ZER: Ring(u32, 16) has fixed capacity. Producer fills what fits.
// Main pops exactly one value and joins — remaining messages are silently dropped
// when the ring goes out of scope. Producer can push into a full ring without hang
// because Ring.push on full ring is a no-op (returns without blocking).

Ring(u32, 16) chan;

void producer() {
    u32 i = 0;
    while (i < 10) {
        chan.push(i);
        i += 1;
    }
}

u32 main() {
    ThreadHandle th = spawn producer();

    // "Receiver exits early" — only pop one message
    u32 got = 0;
    u32 tries = 0;
    while (got == 0 && tries < 10000000) {
        ?u32 val = chan.pop();
        if (val) |v| {
            got = v + 1;  // mark as received (v==0 is valid so use +1)
        }
        tries += 1;
    }

    // Join: producer may have pushed into a full ring — that's safe in ZER
    th.join();

    // We received at least the first message (value 0, got == 1)
    if (got == 0) { return 1; }
    return 0;
}
