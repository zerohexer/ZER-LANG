// Rust source: tests/ui/threads-sendsync/task-comm-16.rs
// Test sending struct and verifying fields through channel.
// Rust: send struct R{val0:0, val1:1, val2:'2'} through channel, verify each field.
// ZER: Ring with struct, push then pop, verify all fields.

struct Record {
    u32 val0;
    u8 val1;
    u32 val2;
}

Ring(Record, 8) rec_chan;

u32 test_struct() {
    Record r;
    r.val0 = 0;
    r.val1 = 1;
    r.val2 = 50;
    rec_chan.push(r);

    ?Record got = rec_chan.pop();
    Record r1 = got orelse return;
    if (r1.val0 != 0) { return 1; }
    if (r1.val1 != 1) { return 2; }
    if (r1.val2 != 50) { return 3; }
    return 0;
}

struct Packet {
    u32 id;
    u32 data;
}

Ring(Packet, 8) pkt_chan;

u32 test_multi() {
    // Send 3 packets
    Packet p1; p1.id = 1; p1.data = 10;
    Packet p2; p2.id = 2; p2.data = 20;
    Packet p3; p3.id = 3; p3.data = 30;
    pkt_chan.push(p1);
    pkt_chan.push(p2);
    pkt_chan.push(p3);

    // Receive and verify FIFO order
    ?Packet g1 = pkt_chan.pop();
    Packet r1 = g1 orelse return;
    if (r1.id != 1) { return 10; }
    if (r1.data != 10) { return 11; }

    ?Packet g2 = pkt_chan.pop();
    Packet r2 = g2 orelse return;
    if (r2.id != 2) { return 12; }

    ?Packet g3 = pkt_chan.pop();
    Packet r3 = g3 orelse return;
    if (r3.id != 3) { return 13; }
    if (r3.data != 30) { return 14; }

    return 0;
}

u32 main() {
    u32 r1 = test_struct();
    if (r1 != 0) { return r1; }
    u32 r2 = test_multi();
    if (r2 != 0) { return r2; }
    return 0;
}
