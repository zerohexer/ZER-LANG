// Condvar: producer signals consumer when data is ready
shared struct Channel {
    u32 data;
    u32 ready;
}

Channel ch;

void producer(*Channel c) {
    c.data = 99;
    c.ready = 1;
    @cond_signal(c);
}

u32 main() {
    ch.ready = 0;
    ch.data = 0;
    ThreadHandle th = spawn producer(&ch);
    @cond_wait(ch, ch.ready > 0);
    u32 val = ch.data;
    th.join();
    if (val != 99) { return 1; }
    return 0;
}
