// Comptime functions returning negative values
// BUG-415: in-place NODE_INT_LIT conversion used uint64_t for negative i32
// Also: eval_const_expr extended to handle resolved comptime calls

comptime i32 NEG() { return -1; }
comptime i32 MIN_VAL() { return -128; }
comptime i32 LEVEL() { return 3; }

u32 main() {
    // Negative comptime result
    i32 n = NEG();
    if (n != -1) { return 1; }

    i32 m = MIN_VAL();
    if (m != -128) { return 2; }

    // Positive comptime result (sanity)
    i32 l = LEVEL();
    if (l != 3) { return 3; }

    // Comptime if with negative comparison
    comptime if (NEG() < 0) {
        u32 x = 1;
        if (x != 1) { return 4; }
    }

    // Comptime if with positive comparison
    comptime if (LEVEL() > 2) {
        u32 y = 2;
        if (y != 2) { return 5; }
    }

    return 0;
}
