// BUG-644: comptime depth counter leak at checker.c:1773 and :1776.
//
// Before fix: when a comptime function called a non-comptime symbol (line
// 1773) or with wrong arity (line 1776), `_comptime_call_depth` was
// incremented but not decremented before the early return. After ~17 such
// leaks, legitimate later comptime calls falsely tripped the "exceeded
// recursion depth (16)" guard.
//
// This test demonstrates a chain of comptime calls that hit the failure
// path repeatedly. With the bug present, late calls report bogus
// "exceeded recursion depth" errors. With the fix, all calls cleanly
// fail with "could not be evaluated at compile time" (correct error)
// and the depth counter returns to zero between attempts.
//
// Test mode: compile must FAIL (we have 20 invalid comptime calls).
// But the failure pattern must NOT include "exceeded recursion depth".
// We can't directly assert this via test_zer.sh, so this lives as a
// positive-compile test using a single VALID comptime call AFTER 20
// failed attempts — proving the counter still allows new calls.

u32 not_comptime(u32 x) { return x; }

// leaker calls a non-comptime function — fails inside the body.
comptime u32 leaker(u32 n) {
    return not_comptime(n);
}

comptime u32 normal(u32 x) { return x + 1; }

void main() {
    // Inside a function body, the comptime evaluator is used at array sizes
    // and static_asserts. Static-asserts give the cleanest test.
    static_assert(normal(5) == 6);
    static_assert(normal(10) == 11);
    static_assert(normal(15) == 16);
}
