// Bounds: proven-safe — loop with explicit bound < array size

u32 main() {
    u32[10] arr;
    for (u32 i = 0; i < 10; i += 1) {
        arr[i] = i + 1;
    }

    u32 sum = 0;
    for (u32 i = 0; i < 5; i += 1) {
        sum += arr[i];
    }
    // 1+2+3+4+5 = 15
    if (sum != 15) { return 1; }
    return 0;
}
