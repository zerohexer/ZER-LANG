// A6-full atomic-cell regression guard (positive): an atomic cell initialized
// AND accessed via @atomic_* everywhere (the strict-model discipline) compiles
// and runs. No plain write to the cell exists.
u32 g;
void worker() { u32 x = @atomic_add(&g, 1); }
u32 main() {
    @atomic_store(&g, 0);
    ThreadHandle th = spawn worker();
    th.join();
    u32 v = @atomic_load(&g);
    if (v != 1) { return 1; }
    return 0;
}
