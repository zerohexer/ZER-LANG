// ?T[N] — array of optionals (not optional of array)
// BUG-413: parser produced OPTIONAL(ARRAY) instead of ARRAY(OPTIONAL)
// Tests: ?Handle(T)[N], ?u32[N], indexing, if-unwrap, == null, assign null

struct Task { u32 id; u32 priority; }
Slab(Task) pool;

u32 test_optional_handle_array() {
    ?Handle(Task)[4] arr;
    arr[0] = pool.alloc();
    arr[1] = null;
    arr[2] = pool.alloc();
    arr[3] = null;

    u32 count = 0;
    for (u32 i = 0; i < 4; i += 1) {
        if (arr[i]) |h| {
            h.id = count;
            count += 1;
        }
    }
    if (count != 2) { return 1; }

    // free allocated handles
    for (u32 i = 0; i < 4; i += 1) {
        if (arr[i]) |h| { pool.free(h); }
    }
    return 0;
}

u32 test_optional_int_array() {
    ?u32[4] data;
    data[0] = 42;
    data[1] = null;
    data[2] = 99;
    data[3] = null;

    u32 sum = 0;
    for (u32 i = 0; i < 4; i += 1) {
        u32 v = data[i] orelse 0;
        sum += v;
    }
    // 42 + 0 + 99 + 0 = 141
    if (sum != 141) { return 1; }
    return 0;
}

u32 test_null_check() {
    ?u32[2] arr;
    arr[0] = 10;
    arr[1] = null;
    if (arr[0] == null) { return 1; }
    if (arr[1] != null) { return 2; }
    return 0;
}

u32 main() {
    if (test_optional_handle_array() != 0) { return 1; }
    if (test_optional_int_array() != 0) { return 2; }
    if (test_null_check() != 0) { return 3; }
    return 0;
}
