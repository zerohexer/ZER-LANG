// Real program 1: Priority task scheduler
// Exercises: Slab, Handle auto-deref, enum switch, for loops, orelse,
//            struct mutation, function calls, optional handles, defer

struct Task {
    u32 id;
    u32 priority;   // lower = higher priority
    u32 deadline;
    bool completed;
}

enum TaskResult { ok, deadline_missed, cancelled }

Slab(Task) tasks;

// Create a new task, returns handle or null if slab full
?Handle(Task) task_create(u32 id, u32 prio, u32 deadline) {
    Handle(Task) h = tasks.alloc() orelse { return null; };
    h.id = id;
    h.priority = prio;
    h.deadline = deadline;
    h.completed = false;
    return h;
}

// Find highest-priority (lowest number) uncompleted task from array
// Returns index into array, or 255 if none found
u32 find_highest_priority(Handle(Task)[8] queue, u32 count) {
    u32 best_idx = 255;
    u32 best_prio = 0xFFFFFFFF;

    for (u32 i = 0; i < count; i += 1) {
        if (i >= 8) { break; }
        bool done = queue[i].completed;
        if (!done) {
            u32 prio = queue[i].priority;
            if (prio < best_prio) {
                best_prio = prio;
                best_idx = i;
            }
        }
    }
    return best_idx;
}

// Execute a task — mark completed, return result based on current time
TaskResult execute_task(Handle(Task) h, u32 current_time) {
    u32 dl = h.deadline;
    if (current_time > dl) {
        h.completed = true;
        return TaskResult.deadline_missed;
    }
    h.completed = true;
    return TaskResult.ok;
}

u32 main() {
    // Create tasks with different priorities
    Handle(Task) t0 = task_create(0, 3, 100) orelse { return 1; };
    Handle(Task) t1 = task_create(1, 1, 50) orelse { return 2; };
    Handle(Task) t2 = task_create(2, 2, 75) orelse { return 3; };
    Handle(Task) t3 = task_create(3, 5, 200) orelse { return 4; };

    // Build queue
    Handle(Task)[8] queue;
    queue[0] = t0;
    queue[1] = t1;
    queue[2] = t2;
    queue[3] = t3;
    u32 count = 4;

    // Execute in priority order
    u32 execution_order = 0;
    u32 completed = 0;

    for (u32 round = 0; round < 4; round += 1) {
        u32 idx = find_highest_priority(queue, count);
        if (idx == 255) { break; }
        if (idx >= 8) { break; }

        u32 task_id = queue[idx].id;
        TaskResult result = execute_task(queue[idx], 60);

        switch (result) {
            .ok => {
                execution_order = execution_order * 10 + task_id;
                completed = completed + 1;
            }
            .deadline_missed => {
                execution_order = execution_order * 10 + task_id;
                completed = completed + 1;
            }
            .cancelled => { }
        }
    }

    // Expected order: t1(prio=1), t2(prio=2), t0(prio=3), t3(prio=5)
    // execution_order should be: 1*1000 + 2*100 + 0*10 + 3 = 1203
    if (execution_order != 1203) { return 10; }
    if (completed != 4) { return 11; }

    // t1 had deadline 50, current_time 60 → deadline_missed
    // Verify t1 is completed
    if (!t1.completed) { return 12; }

    // Clean up
    tasks.free(t0);
    tasks.free(t1);
    tasks.free(t2);
    tasks.free(t3);

    return 0;
}
