/* Audit 2026-04-26: alignment check must always run on @inttoptr with a
 * constant address. Misaligned addresses cause SIGBUS on ARM/RISC-V;
 * the range gate should not silently bypass alignment validation.
 *
 * Range check passes (0x40000001 is inside declared mmio range) but
 * alignment fails (0x40000001 is not 4-byte aligned for *u32).
 *
 * EXPECTED: compile error (alignment violation) */

mmio 0x40000000..0x40000FFF;

i32 main() {
    volatile *u32 reg = @inttoptr(volatile *u32, 0x40000001);
    return 0;
}
