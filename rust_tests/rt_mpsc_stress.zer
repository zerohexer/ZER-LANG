// Rust source: tests/ui/threads-sendsync/mpsc_stress.rs
// 4 writer threads, 100 msgs each, verify total.
// ZER: shared struct sum; 4 threads each add their portion; verify total = 4*100 = 400.

shared struct Accum {
    u32 total;
}

Accum g;

// Each worker adds `count` to the shared total
void writer(*Accum a, u32 count) {
    u32 i = 0;
    while (i < count) {
        a.total += 1;
        i += 1;
    }
}

u32 main() {
    g.total = 0;

    ThreadHandle t1 = spawn writer(&g, 100);
    ThreadHandle t2 = spawn writer(&g, 100);
    ThreadHandle t3 = spawn writer(&g, 100);
    ThreadHandle t4 = spawn writer(&g, 100);
    t1.join();
    t2.join();
    t3.join();
    t4.join();

    u32 total = g.total;
    if (total != 400) { return 1; }
    return 0;
}
