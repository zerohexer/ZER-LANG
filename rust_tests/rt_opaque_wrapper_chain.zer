// Rust pattern: multiple layers of type erasure — wrapper around wrapper.
// ZER: *opaque provenance tracked through function chain.
// NOTE: contexts are global — a funcptr call is worst-case `keep`, so a
// stack-local context is rejected (see docs/limitations.md).

struct HwTimer { u32 prescaler; u32 period; }

struct Driver {
    *opaque hw;
    u32 (*read_period)(*opaque);
}

u32 read_timer_period(*opaque ctx) {
    *HwTimer t = @ptrcast(*HwTimer, ctx);
    return t.period;
}

struct System {
    *opaque driver_ctx;
    u32 (*get_tick)(*opaque);
}

u32 system_tick(*opaque ctx) {
    *Driver d = @ptrcast(*Driver, ctx);
    return d.read_period(d.hw);
}

HwTimer g_timer;
Driver g_drv;

u32 main() {
    g_timer.prescaler = 8;
    g_timer.period = 1000;

    g_drv.hw = @ptrcast(*opaque, &g_timer);
    g_drv.read_period = read_timer_period;

    // Verify direct call
    u32 p = g_drv.read_period(g_drv.hw);
    if (p != 1000) { return 1; }

    // Verify through System wrapper
    System sys;
    sys.driver_ctx = @ptrcast(*opaque, &g_drv);
    sys.get_tick = system_tick;

    u32 tick = sys.get_tick(sys.driver_ctx);
    if (tick != 1000) { return 2; }

    // Modify original, verify propagates
    g_timer.period = 2000;
    tick = sys.get_tick(sys.driver_ctx);
    if (tick != 2000) { return 3; }

    return 0;
}
