// Goto: multiple forward-jump targets, error chain

struct R1 { u32 v; }
struct R2 { u32 v; }
Slab(R1) s1;
Slab(R2) s2;

u32 multi_alloc(bool fail1, bool fail2) {
    ?*R1 mr1 = s1.alloc_ptr();
    *R1 r1 = mr1 orelse { return 1; };

    if (fail1) { goto cleanup1; }

    ?*R2 mr2 = s2.alloc_ptr();
    *R2 r2 = mr2 orelse { s1.free_ptr(r1); return 2; };

    if (fail2) { goto cleanup2; }

    r1.v = 10;
    r2.v = 20;
    u32 sum = r1.v + r2.v;

cleanup2:
    s2.free_ptr(r2);
cleanup1:
    s1.free_ptr(r1);
    return 0;
}

u32 main() {
    return multi_alloc(false, false);
}
