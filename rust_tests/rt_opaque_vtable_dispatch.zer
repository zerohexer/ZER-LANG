// Rust pattern: trait object vtable dispatch — Box<dyn Trait>.method()
// ZER: function pointer + *opaque context for type-erased dispatch.
// NOTE: contexts are global — a funcptr call is worst-case `keep`, so a
// stack-local context is rejected (see docs/limitations.md).

struct Circle { u32 radius; }
struct Square { u32 side; }

u32 circle_area(*opaque ctx) {
    *Circle c = @ptrcast(*Circle, ctx);
    return c.radius * c.radius * 3;
}

u32 square_area(*opaque ctx) {
    *Square s = @ptrcast(*Square, ctx);
    return s.side * s.side;
}

struct Shape {
    *opaque ctx;
    u32 (*area_fn)(*opaque);
}

Circle g_circle;
Square g_square;

u32 main() {
    g_circle.radius = 5;
    Shape s1;
    s1.ctx = @ptrcast(*opaque, &g_circle);
    s1.area_fn = circle_area;

    g_square.side = 4;
    Shape s2;
    s2.ctx = @ptrcast(*opaque, &g_square);
    s2.area_fn = square_area;

    u32 a1 = s1.area_fn(s1.ctx);
    u32 a2 = s2.area_fn(s2.ctx);

    if (a1 != 75) { return 1; }
    if (a2 != 16) { return 2; }
    return 0;
}
