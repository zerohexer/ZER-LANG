// Scoped spawn: ThreadHandle + join allows *T (non-shared) args
struct Work { u32 task_id; u32 result; }

void compute(*Work w) {
    w.result = w.task_id * 10;
}

u32 main() {
    Work w;
    w.task_id = 7;
    w.result = 0;
    ThreadHandle th = spawn compute(&w);
    th.join();
    if (w.result != 70) { return 1; }
    return 0;
}
