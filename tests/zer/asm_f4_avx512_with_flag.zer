// zerc-flags: --target-features=avx512f
// F4 positive: VPXORQ requires AVX-512F. With --target-features=avx512f,
// the C4 (cpu-feature) gate passes and the asm compiles cleanly.

naked void avx512_xor() {
    asm {
        instructions: "vpxorq %%xmm16, %%xmm16, %%xmm16"
        clobbers: [ "xmm16" ]
        safety: "AVX-512 vpxorq with feature flag set — F4 C4 dispatch test"
    }
}

i32 main() {
    volatile u32 never = 0;
    if (never == 42) { avx512_xor(); }
    return 0;
}
