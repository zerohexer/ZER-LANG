// Rust pattern: Rust has NO deadlock detection — ZER does.
// ZER: single statement accessing TWO different shared types = deadlock risk.
// BUG-464: properly detects same-statement multi-lock, not cross-statement.
// EXPECTED: compile error

shared struct Alpha { u32 x; }
shared struct Beta { u32 y; }

Alpha a;
Beta b;

u32 main() {
    // Single statement accessing both Alpha and Beta — deadlock risk
    // Emitter can only lock ONE shared type per statement group.
    a.x = b.y;   // ERROR: accesses both Alpha and Beta in one statement
    return 0;
}
