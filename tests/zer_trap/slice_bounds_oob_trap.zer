// Regression guard for BUG-595 (slice bounds READ).
// MUST compile clean + trap at runtime with "array index out of bounds".
// Pattern: VRP-unprovable index (laundered through a loop) on a slice
// of known length. Without the runtime _zer_bounds_check, this would
// silently read past the slice end.

u32 main() {
    u32[5] arr;
    [*]u32 s = arr[0..];
    u32 i = 10;
    // Launder through loop so VRP can't prove i statically
    for (u32 k = 0; k < 1; k += 1) { i = 10; }
    u32 r = s[i];  // OOB — must trap
    if (r == 999) { return 1; }
    return 0;
}
