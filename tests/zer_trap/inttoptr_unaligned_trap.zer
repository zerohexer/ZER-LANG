// Regression guard for BUG-599 (@inttoptr alignment check, variable addr).
// MUST compile clean + trap at runtime with "unaligned address".
// Pattern: address in valid mmio range but not aligned to target type's
// alignment (u32 requires 4-byte alignment).

mmio 0x40000000..0x40000FFF;

u32 main() {
    u64 addr = 0x40000001;  // in range but unaligned for u32
    for (u32 i = 0; i < 1; i += 1) { addr = 0x40000001; }
    volatile *u32 p = @inttoptr(*u32, addr);
    return p[0];  // alignment check must trap
}
