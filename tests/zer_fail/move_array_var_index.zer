// applied the variable-index barrier to FREE only). Now a hard error.
move struct Token { u32 kind; }
void consume(Token t) { t.kind = t.kind; }
u32 main() {
    Token[4] arr;
    arr[0].kind = 42;
    arr[1].kind = 99;
    u32 i = 1;
    Token m = arr[i];
    consume(m);
    u32 v = arr[0].kind;
    return v;
}
