// A guard-body `return n` returns n >= 100, but find_return_range wrongly credited
// it the guard's inverse range [0,99], eliding the caller's bounds check → stack OOB
// write of arr[150] (pre-fix exit 150). Post-fix: the auto-guard catches it (exit 0).
u32 pick(u32 n) {
    if (n >= 100) { return n; }
    return 0;
}
u32 main() {
    u8[100] arr;
    u32 idx = pick(150);
    arr[idx] = 7;
    return idx;
}
