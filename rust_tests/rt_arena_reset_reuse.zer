// Rust pattern: Arena/bump allocator — alloc many, reset, alloc again.
// ZER: Arena.over() for init, alloc, reset, realloc.

struct Obj { u32 value; }

u8[4096] arena_buf;
Arena scratch;

u32 main() {
    scratch = scratch.over(arena_buf);

    // First round
    ?*Obj m1 = scratch.alloc(Obj);
    *Obj o1 = m1 orelse return;
    o1.value = 10;

    ?*Obj m2 = scratch.alloc(Obj);
    *Obj o2 = m2 orelse return;
    o2.value = 20;

    if (o1.value != 10) { return 1; }
    if (o2.value != 20) { return 2; }

    // Reset — all memory reclaimed
    scratch.reset();

    // Second round
    ?*Obj m3 = scratch.alloc(Obj);
    *Obj o3 = m3 orelse return;
    o3.value = 99;
    if (o3.value != 99) { return 3; }

    return 0;
}
