// Rust pattern: Vec<Box<dyn Any>> — collection of type-erased pointers
// BUG-467 fixed: ?*T[N] now parses as ARRAY(OPTIONAL(POINTER(T)), N).
// No typedef workaround needed.

struct Device { u32 id; u32 status; }
Slab(Device) heap;

u32 main() {
    ?*Device m0 = heap.alloc_ptr();
    *Device d0 = m0 orelse return;
    defer heap.free_ptr(d0);
    d0.id = 0;
    d0.status = 10;

    ?*Device m1 = heap.alloc_ptr();
    *Device d1 = m1 orelse return;
    defer heap.free_ptr(d1);
    d1.id = 1;
    d1.status = 20;

    // Array of optional pointers — native syntax
    ?*Device[2] slots;
    slots[0] = d0;
    slots[1] = d1;

    // Retrieve via unwrap
    *Device r0 = slots[0] orelse return;
    if (r0.status != 10) { return 1; }

    *Device r1 = slots[1] orelse return;
    if (r1.status != 20) { return 2; }

    return 0;
}
