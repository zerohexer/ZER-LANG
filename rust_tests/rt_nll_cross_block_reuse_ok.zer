// Rust NLL: resource freed in inner scope, outer scope allocates fresh.
// ZER: Pool slot freed in block, reallocated cleanly after block exits.


struct Counter { u32 count; u32 max; }
Pool(Counter, 4) pool;

i32 main() {
    u32 total = 0;

    // Block 1: alloc, use, free
    {
        ?Handle(Counter) mh = pool.alloc();
        Handle(Counter) h = mh orelse return;
        pool.get(h).count = 5;
        total += h.count;
        pool.free(h);
    }

    // Block 2: alloc reuses freed slot
    {
        ?Handle(Counter) mh = pool.alloc();
        Handle(Counter) h = mh orelse return;
        pool.get(h).count = 7;
        total += h.count;
        pool.free(h);
    }

    if (total != 12) { return 1; }
    return 0;
}
