// Struct: linked list via Pool handles

struct ListNode { u32 val; ?Handle(ListNode) next; }
Pool(ListNode, 8) node_pool;

u32 main() {
    ?Handle(ListNode) mh1 = node_pool.alloc();
    Handle(ListNode) h1 = mh1 orelse return;

    ?Handle(ListNode) mh2 = node_pool.alloc();
    Handle(ListNode) h2 = mh2 orelse return;

    ?Handle(ListNode) mh3 = node_pool.alloc();
    Handle(ListNode) h3 = mh3 orelse return;

    node_pool.get(h1).val = 10;
    node_pool.get(h1).next = h2;

    node_pool.get(h2).val = 20;
    node_pool.get(h2).next = h3;

    node_pool.get(h3).val = 30;

    u32 sum = node_pool.get(h1).val + node_pool.get(h2).val + node_pool.get(h3).val;
    if (sum != 60) { return 1; }

    node_pool.free(h3);
    node_pool.free(h2);
    node_pool.free(h1);
    return 0;
}
