// Bounds: modulo-based index proven safe (% TABLE_SIZE)

const u32 TABLE_SIZE = 16;
u32[16] table;

u32 get_slot(u32 key) {
    return key % TABLE_SIZE;
}

u32 main() {
    for (u32 i = 0; i < TABLE_SIZE; i += 1) {
        table[i] = 0;
    }
    u32 slot = get_slot(37);
    table[slot] = 99;
    if (table[5] != 99) { return 1; }
    return 0;
}
