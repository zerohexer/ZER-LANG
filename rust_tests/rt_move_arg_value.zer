// Rust source: tests/ui/moves/move-arg.rs
// Pass value to function — ownership transferred.
// ZER: Pass value by copy to function. Verify value.

void test(u32 foo) {
    if (foo != 10) { return; }
}

u32 main() {
    u32 x = 10;
    test(x);
    // x is still valid in ZER (copied, not moved)
    if (x != 10) { return 1; }
    return 0;
}
