// EXPECTED: compile error
// Rust source: tests/ui/threads-sendsync/task-comm-9.rs
// One thread sends 0..9. Main receives and sums. Assert sum == 45.

struct Val { u32 n; }

Ring(Val, 16) chan;

shared struct Done { u32 flag; }
Done sig;

void sender(*Done d) {
    for (u32 i = 0; i < 10; i += 1) {
        Val v;
        v.n = i;
        chan.push(v);
    }
    d.flag = 1;
    @cond_signal(d);
}

u32 main() {
    sig.flag = 0;
    ThreadHandle th = spawn sender(&sig);
    @cond_wait(sig, sig.flag > 0);
    th.join();

    u32 sum = 0;
    for (u32 i = 0; i < 10; i += 1) {
        ?Val r = chan.pop();
        Val v = r orelse return;
        sum += v.n;
    }

    // 0+1+2+...+9 = 45
    if (sum != 45) { return 1; }
    return 0;
}
