// GAP-8 (MEDIUM) — Arena-derived pointer laundered through struct
// field copy + function parameter escapes compile-time check.
//
// The direct pattern `c.ptr = p;` IS caught by the arena escape check
// at checker.c:3879+ (BUG-633: "cannot store arena-derived pointer in
// global"). But the same pointer stored in a local struct field, then
// passed by value to a function that assigns the parameter to the
// global, slips through:
//
//   local.ptr = p;      // local now holds arena-derived ptr
//   take(local);        // take's `ct` param is a COPY of local
//                       //   `ct.ptr` retains the arena pointer
//                       //   no propagation of arena flag through
//                       //   value-typed struct param
//   void take(Container ct) { c = ct; }   // store COPY to global
//
// Compile-time: passes. Runtime: caught only by the libc-malloc-wrap
// fault when c.ptr is later dereferenced after make() returns —
// gives a "memory access fault" trap, not the documented
// "arena-derived pointer escape" compile error. On bare-metal
// without malloc-wrap, fully silent.
//
// Fix sketch: propagate is_arena_derived flag transitively through
// struct field assignments and value-typed struct parameters, OR
// reject value-typed struct args carrying arena-derived fields.

struct Item { u32 v; }
struct Container { *Item ptr; }
Container c;

void take(Container ct) {
    c = ct;  // launder arena-derived through struct copy
}

void make() {
    Arena a;
    *Item p = a.alloc(Item) orelse return;
    p.v = 99;
    Container local;
    local.ptr = p;
    take(local);
}

i32 main() {
    make();
    // c.ptr now dangles — compile time should have caught the escape
    return 0;
}
