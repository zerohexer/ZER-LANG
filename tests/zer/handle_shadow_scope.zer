// Handle variable shadowing — inner scope free doesn't affect outer (BUG-488)
struct Item { u32 val; }
Pool(Item, 8) pool;

u32 main() {
    ?Handle(Item) mh = pool.alloc();
    Handle(Item) h = mh orelse return;
    defer pool.free(h);
    {
        ?Handle(Item) mh2 = pool.alloc();
        Handle(Item) h = mh2 orelse return;
        pool.free(h);
    }
    pool.get(h).val = 42;
    if (pool.get(h).val != 42) { return 1; }
    return 0;
}
