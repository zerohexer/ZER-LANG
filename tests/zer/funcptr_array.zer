// Function pointer arrays via typedef
// BUG-412: emit_type_and_name placed name outside (*) for funcptr arrays

typedef u32 (*UnaryOp)(u32);
typedef u32 (*BinOp)(u32, u32);
typedef void (*Action)(u32);

u32 add1(u32 x) { return x + 1; }
u32 mul2(u32 x) { return x * 2; }
u32 sub3(u32 x) { return x - 3; }
u32 add(u32 a, u32 b) { return a + b; }
u32 mul(u32 a, u32 b) { return a * b; }

u32 counter;
void inc(u32 n) { counter += n; }
void dec(u32 n) { counter -= n; }

u32 test_unary_chain() {
    UnaryOp[3] ops;
    ops[0] = add1;
    ops[1] = mul2;
    ops[2] = sub3;
    u32 val = 10;
    for (u32 i = 0; i < 3; i += 1) {
        val = ops[i](val);
    }
    // 10 → 11 → 22 → 19
    if (val != 19) { return 1; }
    return 0;
}

u32 test_binary() {
    BinOp[2] ops;
    ops[0] = add;
    ops[1] = mul;
    u32 r = ops[0](3, 4) + ops[1](3, 4);
    // 7 + 12 = 19
    if (r != 19) { return 1; }
    return 0;
}

u32 test_void_return() {
    counter = 100;
    Action[2] acts;
    acts[0] = inc;
    acts[1] = dec;
    acts[0](50);
    acts[1](20);
    if (counter != 130) { return 1; }
    return 0;
}

u32 main() {
    if (test_unary_chain() != 0) { return 1; }
    if (test_binary() != 0) { return 2; }
    if (test_void_return() != 0) { return 3; }
    return 0;
}
