// Regression guard for slice end > cap silent OOB.
// MUST compile clean + trap at runtime with "slice end > len".
// Pattern: arr[a..b] with `b > arr.len` previously emitted no runtime check
// because slice_needs_runtime_check only verified `start > end`. Reading
// the resulting slice would silently read past the array end.

i32 main() {
    u8[10] arr;
    u32 lo = 0;
    u32 hi = 50;
    // Launder hi through a loop so VRP can't prove statically.
    for (u32 k = 0; k < 1; k += 1) { hi = 50; }
    [*]u8 sub = arr[lo..hi];  // hi > arr.len (10) — must trap
    if (sub.len > 0) { return 1; }
    return 0;
}
