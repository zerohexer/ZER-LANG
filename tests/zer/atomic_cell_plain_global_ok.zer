// A6-full atomic-cell regression guard (positive): a plain global that is
// NEVER used with @atomic_* is not an atomic cell — plain access stays fine
// (the inclusion model only constrains locations that are actually atomic).
u32 g;
u32 main() {
    g = 5;
    g = g + 1;
    if (g != 6) { return 1; }
    return 0;
}
