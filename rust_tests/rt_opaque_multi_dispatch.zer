// Rust pattern: dynamic dispatch with multiple trait objects in array.
// ZER: Op[N] array with *opaque context — each element has different provenance.
// BUG-466: constant-indexed *opaque arrays now allow per-element provenance.
// NOTE: contexts are global — a funcptr call is worst-case `keep`, so a
// stack-local context is rejected (see docs/limitations.md).

struct Adder { u32 base; }
struct Multiplier { u32 factor; }

u32 add_compute(*opaque ctx, u32 x) {
    *Adder a = @ptrcast(*Adder, ctx);
    return x + a.base;
}

u32 mul_compute(*opaque ctx, u32 x) {
    *Multiplier m = @ptrcast(*Multiplier, ctx);
    return x * m.factor;
}

struct Op {
    *opaque ctx;
    u32 (*compute)(*opaque, u32);
}

Adder g_a;
Multiplier g_m;

u32 main() {
    g_a.base = 10;
    g_m.factor = 3;

    Op[2] ops;
    ops[0].ctx = @ptrcast(*opaque, &g_a);
    ops[0].compute = add_compute;
    ops[1].ctx = @ptrcast(*opaque, &g_m);
    ops[1].compute = mul_compute;

    // Chain: 5 + 10 = 15, 15 * 3 = 45
    u32 val = 5;
    val = ops[0].compute(ops[0].ctx, val);
    if (val != 15) { return 1; }

    val = ops[1].compute(ops[1].ctx, val);
    if (val != 45) { return 2; }

    return 0;
}
