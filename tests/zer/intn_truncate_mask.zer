// F6: @truncate(uN/iN, val) must keep only the low N bits (unsigned) / sign-extend
// from bit N (signed). A bare carrier cast left the high bits set.
u32 main() {
    u32 big = 5000000;
    u21 x = @truncate(u21, big);
    if ((u32)x != (5000000 & 0x1FFFFF)) { return 1; }   // 805696
    u32 allset = 0x1FFFFF;                                // bit20 set
    i21 s = @truncate(i21, allset);
    if ((i32)s != -1) { return 2; }                       // sign-extends to -1
    return 0;
}
