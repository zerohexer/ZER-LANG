// Rust equivalent: Mutex deadlock (ABBA pattern)
// In Rust: detected at runtime by thread poisoning / actual deadlock
// In ZER: detected at COMPILE TIME by lock ordering

shared struct AccountA { u32 balance; }
shared struct AccountB { u32 balance; }

AccountA a;
AccountB b;

// This function accesses B then A — WRONG ORDER
// Should be compile error: deadlock
void bad_transfer() {
    b.balance += 100;
    a.balance += 50;   // ERROR: A (order lower) after B (order higher)
}

u32 main() {
    a.balance = 1000;
    b.balance = 2000;
    return 0;
}
