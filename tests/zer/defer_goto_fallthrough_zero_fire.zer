// BUG sibling of audit_2026-06-17_defer_goto_fallthrough_drops:
// Function-scope `defer` followed by `if (c) { goto L; } L:` silently dropped
// the defer on the fall-through (c=false) path — 0 fires instead of 1.
// The NODE_GOTO eagerly fired+zeroed defer_count; NODE_LABEL's guard install
// (gated on defer_count > 0) was skipped → fall-through emitted nothing.
// Fix 2026-06-29: NODE_GOTO records goto_fired_count on the label;
// NODE_LABEL restores it on a live fall-through and installs the guard.
// Expected: counter == 1 (fires exactly once); regression would give 0.

u32 counter;
void mark() { counter += 1; }
void run(u32 take) {
    defer mark();
    if (take == 1) { goto end; }
    end:
}
u32 main() {
    run(0);
    if (counter == 1) { return 0; }
    return 42;
}
