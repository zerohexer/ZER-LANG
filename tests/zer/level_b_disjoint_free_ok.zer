// audit 2026-07-06 F2: legitimate complementary free/use must still compile
struct Node { u32 val; }
Slab(Node) heap;
bool getflag(u32 x) { if (x > 100) { return true; } return false; }
u32 main() {
    *Node p = heap.alloc_ptr() orelse return;
    p.val = 111;
    bool c = getflag(5);
    if (c) { heap.free_ptr(p); }
    if (!c) { p.val = 7; heap.free_ptr(p); }
    return 0;
}
