// Rust: Condvar + Mutex — producer-consumer pattern
// ZER: @cond_wait + @cond_signal on shared struct

shared struct Buffer {
    u32 item;
    u32 has_item;
}

Buffer buf;

void producer(*Buffer b) {
    b.item = 99;
    b.has_item = 1;
    @cond_signal(b);
}

u32 main() {
    buf.item = 0;
    buf.has_item = 0;

    ThreadHandle th = spawn producer(&buf);
    @cond_wait(buf, buf.has_item > 0);
    u32 val = buf.item;
    th.join();

    if (val != 99) { return 1; }
    return 0;
}
