// Comptime enum values: enum variants evaluable at compile time

enum Color { red, green = 10, blue }
enum Prio { low = 1, med = 5, high = 10 }

static_assert(Color.red == 0, "red should be 0");
static_assert(Color.green == 10, "green should be 10");
static_assert(Color.blue == 11, "blue should be 11");
static_assert(Prio.high == 10, "high should be 10");

comptime u32 BIT(u32 n) { return 1 << n; }

i32 main() {
    u32[12] table;
    table[Color.red] = 100;
    table[Color.green] = 200;
    table[Color.blue] = 300;
    if (table[0] != 100) { return 1; }
    if (table[10] != 200) { return 2; }
    if (table[11] != 300) { return 3; }

    // Enum value as comptime arg (via BIT with int literal equivalent)
    u32 red_bit = BIT(0);
    u32 green_bit = BIT(10);
    if (red_bit != 1) { return 4; }
    if (green_bit != 1024) { return 5; }

    return 0;
}
