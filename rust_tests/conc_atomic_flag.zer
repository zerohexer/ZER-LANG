// Rust: AtomicBool for thread signaling
// ZER: @atomic_store / @atomic_load

u32 done_flag;

void worker(u32 unused) {
    // Signal completion
    @atomic_store(&done_flag, 1);
}

u32 main() {
    done_flag = 0;
    spawn worker(0);
    // In real code: spin on @atomic_load(&done_flag) until 1
    // For test: just verify atomic ops compile
    @atomic_store(&done_flag, 0);
    u32 val = @atomic_load(&done_flag);
    if (val != 0) { return 1; }
    return 0;
}
