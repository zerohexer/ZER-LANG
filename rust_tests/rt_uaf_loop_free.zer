// Rust pattern: free inside loop = use after free on next iteration.
// ZER: free in loop body = compile error.
// EXPECTED: compile error

struct Slot { u32 data; }
Pool(Slot, 4) pool;

u32 main() {
    ?Handle(Slot) ms = pool.alloc();
    Handle(Slot) h = ms orelse return;
    pool.get(h).data = 1;

    u32 i = 0;
    while (i < 3) {
        pool.free(h);   // ERROR: free in loop — UAF on next iteration
        i += 1;
    }

    return 0;
}
