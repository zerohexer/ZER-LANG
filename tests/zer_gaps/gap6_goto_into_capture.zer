// GAP #6 (2026-04-19 audit)
// CLAIM: `goto` into the body of an if-unwrap without traversing
//        the capture binding should error — jumping bypasses the
//        `|v| = unwrap(maybe)` initialization.
// EFFECT: emitted C declares `v` as a local auto-zero'd to 0. The
//         if-unwrap branch would have assigned it from maybe, but
//         the goto skips the branch. `return v` returns 0 silently
//         instead of 42.
// FIX APPROACH: label-reachability analysis — forbid goto targets
//               that are inside an if-unwrap arm or switch-capture
//               arm from outside that arm. Medium effort.

u32 main() {
    ?u32 maybe = 42;
    goto inside;
    if (maybe) |v| {
inside:
        return v;       // v is uninitialized here (auto-zero = 0)
    }
    return 0;
}
