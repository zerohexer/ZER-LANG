// Rust source: tests/ui/drop/drop-on-ret.rs
// Resource dropped on early return — no leak.
// ZER: defer fires on return, handles freed.

struct Resource { u32 data; }
Pool(Resource, 4) pool;

u32 f() {
    ?Handle(Resource) mh = pool.alloc();
    Handle(Resource) h = mh orelse return;
    defer pool.free(h);
    pool.get(h).data = 42;

    if (true) {
        return 1;
    }
    return 0;
}

u32 main() {
    u32 r = f();
    if (r != 1) { return 1; }
    return 0;
}
