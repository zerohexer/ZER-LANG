// Bounds: proven-safe loop index within array length — no runtime check needed

u32 main() {
    u32[8] arr;
    for (u32 i = 0; i < 8; i += 1) {
        arr[i] = i * 2;
    }
    u32 sum = 0;
    for (u32 i = 0; i < 8; i += 1) {
        sum += arr[i];
    }
    // 0+2+4+6+8+10+12+14 = 56
    if (sum != 56) { return 1; }
    return 0;
}
