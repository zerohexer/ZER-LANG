// EXPECTED: compile error
// scan_unsafe_global_access must recurse into NODE_TYPECAST (BH-18 sibling of #7).
// A non-shared global read wrapped in a C-style cast inside a spawned function
// body silently laundered past the data-race check.
u32 g_counter;

void worker() {
    u32 x = (u32)g_counter;
    if (x > 0) { return; }
}

u32 main() {
    spawn worker();
    return 0;
}
