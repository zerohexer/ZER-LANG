// Regression: assignment and compound-assignment to a non-native uN/iN must wrap
// (uN mask / iN sign-extend). Previously only var-decl init was masked; plain
// assignment / += / -= / *= / <<= / @truncate stores skipped the mask, silently
// producing wrong values and out-of-bounds indices.
struct S { u3 f; }
u3 g;
u32 main() {
    u3 a = 7; u3 b = 1;
    u3 y = 7; y = a + b;            if (y != 0) { return 1; }   // wrap
    u3 s = 0; s -= 1;              if (s != 7) { return 2; }   // underflow wrap
    u3 c = a + b;                  if (c != 0) { return 3; }   // var-decl (was ok)
    S st; st.f = 7; st.f += 1;     if (st.f != 0) { return 4; } // struct field
    g = 7; g += 1;                 if (g != 0) { return 5; }   // global
    u3 m = 3; m *= 3;              if (m != 1) { return 6; }   // 9 & 7 == 1
    u3 t = 1; t <<= 3;             if (t != 0) { return 7; }   // over-width shift
    u3 tr = 0; tr = @truncate(u3, 13); if (tr != 5) { return 8; } // 13 & 7 == 5
    i3 d = 3; i3 e = 1; d = d + e; if (d != -4) { return 9; }  // signed wrap
    return 0;
}
