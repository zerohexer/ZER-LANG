// Rust NLL: nested loops — inner loop borrow doesn't outlive to outer loop.
// ZER: inner loop alloc+free per iteration, outer loop iterates cleanly.

struct Cell { u32 row; u32 col; u32 val; }
Pool(Cell, 8) pool;

i32 main() {
    u32 total = 0;
    for (u32 r = 0; r < 3; r += 1) {
        for (u32 c = 0; c < 2; c += 1) {
            ?Handle(Cell) mh = pool.alloc();
            Handle(Cell) h = mh orelse return;
            pool.get(h).row = r;
            pool.get(h).col = c;
            pool.get(h).val = r * 10 + c;
            total += h.val;
            pool.free(h);
        }
    }
    // total = 0+1 + 10+11 + 20+21 = 63
    if (total != 63) { return 1; }
    return 0;
}
