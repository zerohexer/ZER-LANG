// Regression: `return ... orelse arr[0..]` — orelse fallback contains a
// slice-of-local-array. The return-escape walker walks both expr and
// fallback roots; the fallback root NODE_SLICE must be descended.
[*]u32 leak() {
    u32[4] arr;
    arr[0] = 33;
    ?[*]u32 opt = arr[0..];
    return opt orelse arr[0..];
}

u32 main() {
    return leak()[0];
}
