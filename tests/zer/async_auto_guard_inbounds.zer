// Positive: async with VRP-unprovable index but always in bounds.
// Auto-guard inserted; trap doesn't fire because index stays < 8.

u32[8] arr;

async void worker(u32 in) {
    u32 i = in;
    arr[i] = 42;
    yield;
}

i32 main() {
    _zer_async_worker s;
    _zer_async_worker_init(&s, 3);  // in bounds
    _zer_async_worker_poll(&s);
    if (arr[3] != 42) { return 1; }
    return 0;
}
