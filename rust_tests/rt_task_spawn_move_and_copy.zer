// Rust source: tests/ui/threads-sendsync/task-spawn-move-and-copy.rs
// Move Box to thread, verify value preserved (address same after move).
// ZER: Scoped spawn with *T, thread reads value, main verifies after join.

struct Data { u32 value; }

void reader(*Data d, *Data result) {
    result.value = d.value;
}

u32 main() {
    Data d;
    d.value = 12345;
    Data result;
    result.value = 0;
    ThreadHandle th = spawn reader(&d, &result);
    th.join();
    if (result.value != 12345) { return 1; }
    return 0;
}
