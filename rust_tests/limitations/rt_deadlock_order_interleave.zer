// Rust pattern: Rust has NO deadlock detection — ZER does.
// ZER: lock ordering by type_id — ascending order is safe.
//
// LIMITATION: ZER's lock ordering tracks "last accessed type_id" per function.
// Once Beta is accessed (line 14), any subsequent Alpha access (line 17) is
// considered descending order — even though each access is an independent
// lock/unlock with no held-lock overlap.
//
// The pattern: write Alpha, write Beta, read Alpha, read Beta — is safe in
// practice (no locks held simultaneously), but the checker is conservative
// and rejects it because another thread could interleave.
//
// Fix complexity: ~100 lines — track lock ordering per statement-group
// (block-level grouping) instead of per function. Adjacent accesses to the
// same shared struct are already grouped. The issue is cross-group ordering.
//
// Workaround: access all Alpha fields before any Beta fields, or use
// separate functions for each shared struct access.
//
// EXPECTED: compile error (limitation — should be safe)

shared struct Alpha { u32 x; }
shared struct Beta { u32 y; }

Alpha a;
Beta b;

u32 main() {
    a.x = 10;
    b.y = 20;

    // This read of Alpha after Beta triggers deadlock detection
    if (a.x != 10) { return 1; }
    if (b.y != 20) { return 2; }

    return 0;
}
