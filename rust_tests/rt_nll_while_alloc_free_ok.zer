// Rust NLL: borrow scoped to each while iteration — no cross-iteration conflict.
// ZER: alloc+free each while iteration. Each iteration has clean state.

struct Msg { u32 seq; u32 data; }
Pool(Msg, 4) pool;

i32 main() {
    u32 total = 0;
    u32 i = 0;
    while (i < 3) {
        ?Handle(Msg) mh = pool.alloc();
        Handle(Msg) h = mh orelse return;
        pool.get(h).seq = i;
        pool.get(h).data = (i + 1) * 10;
        total += h.data;
        pool.free(h);
        i += 1;
    }
    // total = 10 + 20 + 30 = 60
    if (total != 60) { return 1; }
    return 0;
}
