// Rust pattern: Simple new/drop pattern — Task.alloc() / Task.free() auto-slab sugar.
// ZER: Task.alloc(), use handle, Task.free(h). POSITIVE.

struct Job {
    u32 job_id;
    u32 priority;
    u32 status;
}

i32 main() {
    ?Handle(Job) mh = Job.alloc();
    Handle(Job) h = mh orelse return;

    h.job_id = 1001;
    h.priority = 5;
    h.status = 0;

    h.status = 1;

    if (h.job_id != 1001) {
        Job.free(h);
        return 1;
    }
    if (h.priority != 5) {
        Job.free(h);
        return 1;
    }
    if (h.status != 1) {
        Job.free(h);
        return 1;
    }

    Job.free(h);
    return 0;
}
