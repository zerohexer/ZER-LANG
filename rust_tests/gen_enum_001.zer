// Enum: exhaustive switch on enum — all arms required

enum Color { red, green, blue }

u32 color_code(Color c) {
    switch (c) {
        .red => { return 1; }
        .green => { return 2; }
        .blue => { return 3; }
    }
}

u32 main() {
    if (color_code(Color.red) != 1) { return 1; }
    if (color_code(Color.green) != 2) { return 2; }
    if (color_code(Color.blue) != 3) { return 3; }
    return 0;
}
