// Rust: thread::scope — scoped spawn processes array data
// ZER: scoped spawn reads/writes local array via struct wrapper
// Equivalent to: Rust scoped borrow of slice

struct Buffer {
    u32[16] data;
    u32 len;
    u32 checksum;
}

void compute_checksum(*Buffer b) {
    u32 sum = 0;
    u32 i = 0;
    while (i < b.len) {
        sum += b.data[i];
        i += 1;
    }
    b.checksum = sum;
}

u32 main() {
    Buffer buf;
    buf.len = 8;
    buf.checksum = 0;
    buf.data[0] = 1;
    buf.data[1] = 2;
    buf.data[2] = 3;
    buf.data[3] = 4;
    buf.data[4] = 5;
    buf.data[5] = 6;
    buf.data[6] = 7;
    buf.data[7] = 8;

    ThreadHandle th = spawn compute_checksum(&buf);
    th.join();

    // 1+2+3+4+5+6+7+8 = 36
    if (buf.checksum != 36) { return 1; }
    return 0;
}
