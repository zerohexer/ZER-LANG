// Rust source: tests/ui/threads-sendsync/issue-4446.rs
// Safety scenario: send a string through channel to a thread.
// Thread receives the string and verifies its contents.
// In Rust: channel<String> — ownership of heap string transferred to thread.
// ZER equivalent: shared struct with a flag and a u32 payload (string length
// as proxy for "data received correctly"). Thread waits for flag, reads data.
// Safety property: thread does not access data until sender signals it's ready.

shared struct Message {
    u32 ready;
    u32 length;
}

Message gmsg;

void receiver(*Message m) {
    @cond_wait(m, m.ready > 0);
    // In Rust: thread would use the received string. Here we verify length.
}

u32 main() {
    gmsg.ready = 0;
    // "hello, world" has length 12
    gmsg.length = 12;

    ThreadHandle th = spawn receiver(&gmsg);

    // Simulate sending: set data then signal
    gmsg.ready = 1;
    @cond_signal(gmsg);

    th.join();

    // Verify the message length was set correctly (proxy for string transfer)
    u32 v = gmsg.length;
    if (v != 12) { return 1; }
    return 0;
}
