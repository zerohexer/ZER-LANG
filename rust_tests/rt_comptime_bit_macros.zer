// Rust pattern: #define BIT(n) (1 << n) — C macro replaced by comptime
// ZER: comptime functions replace #define macros

comptime u32 BIT(u32 n) { return 1 << n; }
comptime u32 MASK(u32 hi, u32 lo) { return (1 << (hi + 1)) - (1 << lo); }
comptime u32 MAX(u32 a, u32 b) {
    if (a > b) { return a; }
    return b;
}
comptime u32 MIN(u32 a, u32 b) {
    if (a < b) { return a; }
    return b;
}

u32 main() {
    u32 b0 = BIT(0);
    u32 b3 = BIT(3);
    u32 b7 = BIT(7);
    if (b0 != 1) { return 1; }
    if (b3 != 8) { return 2; }
    if (b7 != 128) { return 3; }

    u32 m = MASK(7, 4);
    // bits 7..4 = 0xF0 = 240
    if (m != 240) { return 4; }

    u32 mx = MAX(10, 20);
    if (mx != 20) { return 5; }

    u32 mn = MIN(10, 20);
    if (mn != 10) { return 6; }

    return 0;
}
