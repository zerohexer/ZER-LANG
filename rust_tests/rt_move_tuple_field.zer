// Rust source: tests/ui/moves/move-out-of-tuple-field.rs
// Safety intent: use field after it was moved = error.
// ZER: struct field free then access = error via handle tracking.

struct Pair { u32 first; u32 second; }
Pool(Pair, 4) pool;

u32 main() {
    // Allocate and use — safe pattern
    ?Handle(Pair) mp = pool.alloc();
    Handle(Pair) h = mp orelse return;
    defer pool.free(h);

    pool.get(h).first = 10;
    pool.get(h).second = 20;

    // Read both fields — valid
    u32 a = pool.get(h).first;
    u32 b = pool.get(h).second;

    if (a != 10) { return 1; }
    if (b != 20) { return 2; }

    return 0;
}
