// Positive: multi-arg scoped spawn, no parent write between spawn and join.
void worker(*u32 a, *u32 b) { *a += 1; *b += 1; }
u32 main() {
    u32 x = 0; u32 y = 0;
    ThreadHandle th = spawn worker(&x, &y);
    th.join();
    x += 1; y += 1;
    if (x != 2) { return 1; }
    if (y != 2) { return 1; }
    return 0;
}
