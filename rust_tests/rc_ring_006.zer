// Rust: mpsc — producer thread sends, main receives
// ZER: spawn producer that pushes to Ring, main pops
// Equivalent to: task-comm-1 (threaded producer)

shared struct Done { u32 flag; }
Done gd;

Ring(u32, 16) chan;

void producer(u32 count) {
    u32 i = 0;
    while (i < count) {
        chan.push(i);
        i += 1;
    }
    gd.flag = 1;
    @cond_signal(gd);
}

u32 main() {
    gd.flag = 0;

    ThreadHandle th = spawn producer(5);

    @cond_wait(gd, gd.flag > 0);
    th.join();

    u32 sum = 0;
    u32 j = 0;
    while (j < 5) {
        ?u32 val = chan.pop();
        if (val) |v| {
            sum += v;
        }
        j += 1;
    }

    // 0+1+2+3+4 = 10
    if (sum != 10) { return 1; }
    return 0;
}
