// keep-universalization 2a + field-level keep (2026-06-07): a `keep` pointer
// parameter (a borrow) CAN be stored into a struct field declared `keep` (the
// field's borrow-ness is audit-visible). Must compile + run + exit 0.
struct Holder { keep ?*u32 hp; }
u32 gv = 42;
void store(*Holder h, keep *u32 p) {
    h.hp = p;
}
u32 main() {
    Holder box;
    store(&box, &gv);
    *u32 got = box.hp orelse { return 1; };
    if (got[0] != 42) { return 2; }
    return 0;
}
