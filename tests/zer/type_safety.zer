// Real program 8: Type safety showcase
// Exercises: distinct typedefs, @cast, @truncate, @saturate, @bitcast,
//            optional chaining, bool logic, integer width conversions

distinct typedef u32 Meters;
distinct typedef u32 Seconds;
distinct typedef u32 MetersPerSecond;

MetersPerSecond compute_speed(Meters distance, Seconds time) {
    u32 d = @cast(u32, distance);
    u32 t = @cast(u32, time);
    if (t == 0) { return @cast(MetersPerSecond, 0); }
    u32 speed = d / t;
    return @cast(MetersPerSecond, speed);
}

// Integer width conversions
u8 clamp_to_byte(u32 val) {
    return @saturate(u8, val);
}

u16 truncate_to_u16(u32 val) {
    return @truncate(u16, val);
}

// Bitcast for reinterpretation
u32 float_bits(f32 val) {
    return @bitcast(u32, val);
}

// Optional chaining pattern
?u32 safe_divide(u32 a, u32 b) {
    if (b == 0) { return null; }
    return a / b;
}

?u32 safe_divide_chain(u32 a, u32 b, u32 c) {
    u32 first = safe_divide(a, b) orelse { return null; };
    return safe_divide(first, c);
}

u32 main() {
    // Distinct typedef safety
    Meters dist = @cast(Meters, 1000);
    Seconds time = @cast(Seconds, 10);
    MetersPerSecond speed = compute_speed(dist, time);
    u32 raw_speed = @cast(u32, speed);
    if (raw_speed != 100) { return 1; }

    // Zero time → zero speed (not crash)
    Seconds zero_time = @cast(Seconds, 0);
    MetersPerSecond zero_speed = compute_speed(dist, zero_time);
    if (@cast(u32, zero_speed) != 0) { return 2; }

    // Saturation
    u8 sat1 = clamp_to_byte(200);
    if (sat1 != 200) { return 3; }

    u8 sat2 = clamp_to_byte(300);
    if (sat2 != 255) { return 4; }  // clamped to 255

    u8 sat3 = clamp_to_byte(0);
    if (sat3 != 0) { return 5; }

    // Truncation
    u16 tr1 = truncate_to_u16(0xABCD);
    if (tr1 != 0xABCD) { return 6; }

    u16 tr2 = truncate_to_u16(0x12345678);
    if (tr2 != 0x5678) { return 7; }  // keeps low 16 bits

    // Float bitcast
    u32 zero_bits = float_bits(0.0);
    if (zero_bits != 0) { return 8; }

    // Optional chaining
    u32 chain1 = safe_divide_chain(100, 5, 2) orelse { return 9; };
    if (chain1 != 10) { return 10; }  // 100/5=20, 20/2=10

    // Chain with zero divisor
    ?u32 chain2 = safe_divide_chain(100, 0, 2);
    if (chain2) |v| { return 11; }  // should be null

    ?u32 chain3 = safe_divide_chain(100, 5, 0);
    if (chain3) |v| { return 12; }  // should be null (second div)

    return 0;
}
