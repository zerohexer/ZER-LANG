// GAP-1 (HIGH) — Silent type confusion via @ptrcast
//
// CLAUDE.md and reference.md describe @ptrcast as
// "provenance-tracked, qualifier-checked." In fact, the provenance check
// at checker.c:6262 only fires when the SOURCE is `*opaque`. A direct
// `@ptrcast(*B, &a)` where both `*A` and `*B` are concrete unrelated
// types falls through to a plain C cast — no compile-time check, no
// runtime check.
//
// Two safer paths exist: explicit `*opaque` round-trip (provenance
// check fires), or `@pun(*T, src)` which DOES insert a runtime
// `_zer_opaque.type_id` mismatch trap. `@ptrcast` between concrete
// types should either reject at compile time (request `@pun`) or
// emit the same runtime check `@pun` emits.
//
// Reproduces: compile clean, returns 42 (low byte of A.x read as B.y).

struct A { u32 x; }
struct B { u32 y; }

i32 main() {
    A a;
    a.x = 42;
    *A pa = &a;
    *B pb = @ptrcast(*B, pa);  // should reject or insert runtime check
    return (i32)pb.y;          // reads A.x as B.y — silent type confusion
}
