// Rust source: tests/ui/borrowck/borrowck-assign-comp-idx.rs
// Borrow slice, modify through index → conflict.
// ZER: array modification through index — bounds-checked, safe.

u32 main() {
    u32[4] arr;
    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    arr[3] = 40;

    // Modify through index — bounds checked
    arr[2] = 99;
    if (arr[2] != 99) { return 1; }

    // Sum all
    u32 sum = 0;
    for (u32 i = 0; i < 4; i += 1) {
        sum += arr[i];
    }
    // 10 + 20 + 99 + 40 = 169
    if (sum != 169) { return 2; }
    return 0;
}
