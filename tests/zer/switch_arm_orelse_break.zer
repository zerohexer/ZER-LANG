// BUG-579b — orelse break inside enum switch arm (terminator fallback)
?u32 maybe_by_i(u32 i) { if (i == 2) { return null; } return i + 100; }

enum S { running, done }

u32 main() {
    S s = S.running;
    u32 total = 0;
    u32 i = 0;
    for (i = 0; i < 5; i += 1) {
        switch (s) {
            .running => {
                u32 v = maybe_by_i(i) orelse break;
                total += v;
            }
            .done => {}
        }
    }
    // Iterations: i=0 → v=100, total=100; i=1 → v=101, total=201;
    // i=2 → null → break. Total should be 201.
    if (total != 201) { return 1; }
    return 0;
}
