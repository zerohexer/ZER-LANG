// Rust pattern: AtomicBool CAS for manual spinlock
// ZER: @atomic_cas loop for lock, @atomic_store for unlock

u32 lock_flag;
shared struct Total { u32 value; }
Total g_total;

void locked_increment(*Total t, u32 amount) {
    // Spin until we acquire
    while (!@atomic_cas(&lock_flag, 0, 1)) { }
    // Critical section — manually locked
    t.value += amount;
    // Release
    @atomic_store(&lock_flag, 0);
}

u32 main() {
    lock_flag = 0;
    g_total.value = 0;
    ThreadHandle t1 = spawn locked_increment(&g_total, 10);
    ThreadHandle t2 = spawn locked_increment(&g_total, 20);
    ThreadHandle t3 = spawn locked_increment(&g_total, 30);
    t1.join();
    t2.join();
    t3.join();
    u32 val = g_total.value;
    if (val != 60) { return 1; }
    return 0;
}
