// Level 2: zercheck + alloc_ptr — pointer invalidated after free
// Exercises: alloc_ptr, use, free, new alloc (no stale reuse)

struct Data { u32 x; u32 y; }
Slab(Data) heap;

u32 test_lifecycle() {
    *Data d = heap.alloc_ptr() orelse { return 1; };
    d.x = 10;
    d.y = 20;
    heap.free_ptr(d);
    // d is now invalid — zercheck prevents use
    return 0;
}

u32 test_sequential() {
    *Data a = heap.alloc_ptr() orelse { return 1; };
    a.x = 1;
    heap.free_ptr(a);

    *Data b = heap.alloc_ptr() orelse { return 2; };
    b.x = 2;
    heap.free_ptr(b);

    *Data c = heap.alloc_ptr() orelse { return 3; };
    c.x = 3;
    c.y = c.x + 1;
    heap.free_ptr(c);
    return 0;
}

u32 main() {
    if (test_lifecycle() != 0) { return 1; }
    if (test_sequential() != 0) { return 2; }
    return 0;
}
