// Rust: ABBA deadlock — detected at runtime by thread hang
// ZER: detected at COMPILE TIME — single statement accessing two shared types.
// BUG-464: deadlock only when two locks held simultaneously (same statement).
// EXPECTED: compile error

shared struct BankA { u32 balance; }
shared struct BankB { u32 balance; }

BankA account_a;
BankB account_b;

// Transfer A→B: single statement accessing both — DEADLOCK RISK
void transfer_ab(u32 amount) {
    account_a.balance = account_b.balance + amount;  // ERROR: accesses both A and B
}

u32 main() {
    account_a.balance = 1000;
    account_b.balance = 2000;
    return 0;
}
