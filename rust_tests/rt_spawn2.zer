// Rust source: tests/ui/threads-sendsync/spawn2.rs
// Safety scenario: thread captures a variable by move (closure captures).
// Rust: move || { use(captured_val) } — value moved into closure for thread.
// ZER: spawn func(value) — value copied into thread's parameter.
// Parent's copy is independent; thread has its own copy of the value.
// Safety property: move semantics ensure thread has exclusive access to its copy.

shared struct Output {
    u32 result;
}

Output gout;

void compute(*Output o, u32 captured) {
    o.result = captured * captured;
}

u32 main() {
    gout.result = 0;
    u32 my_val = 7;

    // Value "moved" (copied in ZER) into thread
    ThreadHandle th = spawn compute(&gout, my_val);
    th.join();

    u32 v = gout.result;
    if (v != 49) { return 1; }
    return 0;
}
