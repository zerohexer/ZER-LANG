// Rust pattern: Loop with Box::new each iteration, dropped at end of iteration.
// ZER: for loop with pool alloc + defer free each iteration. POSITIVE.

struct Chunk {
    u32 iteration;
    u32 value;
}

Pool(Chunk, 4) pool;

u32 compute(u32 i) {
    return i * i;
}

i32 main() {
    u32 total = 0;

    for (u32 i = 0; i < 4; i += 1) {
        ?Handle(Chunk) mh = pool.alloc();
        Handle(Chunk) h = mh orelse return;
        h.iteration = i;
        h.value = compute(i);
        total += h.value;
        pool.free(h);
    }

    if (total != 14) {
        return 1;
    }
    return 0;
}
