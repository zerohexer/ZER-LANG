// Distinct typedef wrapping float — use f64 to match literal type

distinct typedef f64 Celsius;
distinct typedef f64 Fahrenheit;

Fahrenheit to_fahrenheit(Celsius c) {
    f64 raw = @cast(f64, c);
    f64 result = raw + 32.0;
    return @cast(Fahrenheit, result);
}

u32 main() {
    Celsius temp = @cast(Celsius, 100.0);
    Fahrenheit f = to_fahrenheit(temp);
    f64 raw_f = @cast(f64, f);
    // 100.0 + 32.0 = 132.0
    if (raw_f < 131.0) { return 1; }
    if (raw_f > 133.0) { return 2; }
    return 0;
}
