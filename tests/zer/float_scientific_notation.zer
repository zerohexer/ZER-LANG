// Float scientific notation literals must lex and parse.
// Pre-fix: `1.0e20` and friends caused "expected ';' after variable declaration".
// Post-fix: standard C float exponent forms accepted; strtod handles the rest.

i32 main() {
    f64 a = 1.0e20;
    f64 b = 1.5E10;
    f64 c = 1.5e+10;
    f64 d = 1.5e-10;
    f64 e = 1e3;
    f64 f = 5E-2;

    if (a < 9.9e19) { return 1; }
    if (a > 1.1e20) { return 2; }
    if (b < 1.49e10) { return 3; }
    if (c < 1.49e10) { return 4; }
    if (d > 1.51e-10) { return 5; }
    if (e < 999.9) { return 6; }
    if (f > 0.051) { return 7; }
    return 0;
}
