// Complex safe patterns — alloc_ptr + Handle mixed, no false positives

struct Task { u32 id; u32 priority; }
struct Ctx { u32 flags; }

Slab(Task) heap;
Pool(Ctx, 8) ctx_pool;

// Pattern 1: alloc_ptr basic lifecycle
u32 test_basic() {
    *Task t = heap.alloc_ptr() orelse { return 1; };
    t.id = 42;
    t.priority = 3;
    heap.free_ptr(t);
    return 0;
}

// Pattern 2: conditional use, single free
u32 test_conditional(bool flag) {
    *Task t = heap.alloc_ptr() orelse { return 1; };
    if (flag) {
        t.id = 1;
    } else {
        t.id = 2;
    }
    heap.free_ptr(t);
    return 0;
}

// Pattern 3: multiple allocs, free all
u32 test_multiple() {
    *Task a = heap.alloc_ptr() orelse { return 1; };
    *Task b = heap.alloc_ptr() orelse { return 2; };
    a.id = 1;
    b.id = 2;
    if (a.id != 1) { return 3; }
    if (b.id != 2) { return 4; }
    heap.free_ptr(a);
    heap.free_ptr(b);
    return 0;
}

// Pattern 4: Pool alloc_ptr
u32 test_pool() {
    *Ctx c = ctx_pool.alloc_ptr() orelse { return 1; };
    c.flags = 42;
    if (c.flags != 42) { return 2; }
    ctx_pool.free_ptr(c);
    return 0;
}

// Pattern 5: Handle and alloc_ptr mixed
u32 test_mixed() {
    Handle(Task) h = heap.alloc() orelse { return 1; };
    h.id = 10;
    *Task t = heap.alloc_ptr() orelse { return 2; };
    t.id = 20;
    if (h.id != 10) { return 3; }
    if (t.id != 20) { return 4; }
    heap.free(h);
    heap.free_ptr(t);
    return 0;
}

u32 main() {
    if (test_basic() != 0) { return 1; }
    if (test_conditional(true) != 0) { return 2; }
    if (test_conditional(false) != 0) { return 3; }
    if (test_multiple() != 0) { return 4; }
    if (test_pool() != 0) { return 5; }
    if (test_mixed() != 0) { return 6; }
    return 0;
}
