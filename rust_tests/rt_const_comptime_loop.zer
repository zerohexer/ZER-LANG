// Comptime with for loop — compute factorial at compile time.

comptime u32 FACTORIAL(u32 n) {
    u32 result = 1;
    for (u32 i = 1; i <= n; i += 1) {
        result = result * i;
    }
    return result;
}

comptime u32 SUM_TO(u32 n) {
    u32 total = 0;
    u32 i = 0;
    while (i < n) {
        i += 1;
        total += i;
    }
    return total;
}

comptime u32 POWER(u32 base, u32 exp) {
    u32 result = 1;
    for (u32 i = 0; i < exp; i += 1) {
        result = result * base;
    }
    return result;
}

i32 main() {
    u32 f5 = FACTORIAL(5);     // 120
    u32 s10 = SUM_TO(10);     // 55
    u32 p23 = POWER(2, 3);    // 8

    if (f5 != 120) { return 1; }
    if (s10 != 55) { return 2; }
    if (p23 != 8) { return 3; }

    // Use in array size
    u8[FACTORIAL(4)] buf;     // 24-element array
    if (@size(u8) * 24 != 24) { return 4; }

    return 0;
}
