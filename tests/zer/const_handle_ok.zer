// const Handle — const key, mutable data (like const int fd)
// const Handle means can't REASSIGN handle, CAN modify data through it

struct Task { u32 id; }
Pool(Task, 8) tasks;

u32 main() {
    const Handle(Task) h = tasks.alloc() orelse { return 1; };
    h.id = 42;           // OK — modifying data, not reassigning handle
    if (h.id != 42) { return 2; }
    tasks.free(h);
    return 0;
}
