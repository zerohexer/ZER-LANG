// EXPECTED: compile error
// @atomic_store must take pointer-to-integer with width 1/2/4/8 bytes.
// Bug: store/cas paths skipped width validation that the load/arith paths had.
// Passing pointer-to-non-integer (struct, slice, packed) silently accepted.

struct NotInt { u8 a; u32 b; u8 c; }

void main() {
    NotInt v;
    @atomic_store(&v, v);
}
