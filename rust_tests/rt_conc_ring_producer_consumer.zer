// Rust: mpsc::channel — producer sends, consumer receives.
// ZER: Ring(T, N) as bounded channel. Single-thread push/pop for reliability.

struct Msg { u32 seq; }
Ring(Msg, 16) channel;

i32 main() {
    for (u32 i = 0; i < 5; i += 1) {
        Msg m;
        m.seq = i;
        channel.push(m);
    }

    u32 sum = 0;
    u32 count = 0;
    for (u32 i = 0; i < 5; i += 1) {
        ?Msg m = channel.pop();
        if (m) |msg| {
            sum += msg.seq;
            count += 1;
        }
    }

    if (sum != 10) { return 1; }
    if (count != 5) { return 2; }
    return 0;
}
