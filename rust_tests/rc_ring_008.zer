// EXPECTED: compile error
// Rust: mpsc — multiple senders, single consumer
// ZER: two spawned producers push to shared Ring, main drains
// Equivalent to: task-comm-17 (multi-sender)

shared struct Sync { u32 done; }
Sync gsync;

Ring(u32, 32) chan;

void sender_a(u32 base) {
    u32 i = 0;
    while (i < 4) {
        chan.push(base + i);
        i += 1;
    }
    gsync.done += 1;
    @cond_signal(gsync);
}

void sender_b(u32 base) {
    u32 i = 0;
    while (i < 4) {
        chan.push(base + i);
        i += 1;
    }
    gsync.done += 1;
    @cond_signal(gsync);
}

u32 main() {
    gsync.done = 0;

    ThreadHandle ta = spawn sender_a(0);
    ThreadHandle tb = spawn sender_b(100);

    ta.join();
    tb.join();

    // Drain all 8 items — order may vary but sum must be correct
    // sender_a pushes 0+1+2+3=6, sender_b pushes 100+101+102+103=406 → total 412
    u32 sum = 0;
    u32 i = 0;
    while (i < 8) {
        ?u32 val = chan.pop();
        if (val) |v| {
            sum += v;
        }
        i += 1;
    }

    if (sum != 412) { return 1; }
    return 0;
}
