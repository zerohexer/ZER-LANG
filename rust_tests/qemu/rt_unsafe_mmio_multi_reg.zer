// QEMU variant of rt_unsafe_mmio_multi_reg.
//
// See rt_unsafe_mmio_volatile_rw.zer for address remapping rationale.
// This test verifies multiple volatile pointers derived from a single
// declared mmio range all compile and access their addresses correctly
// under QEMU Cortex-M3 semihosting.

mmio 0x40024000..0x40024FFF;

i32 main() {
    volatile *u32 gpio_moder = @inttoptr(*u32, 0x40024000);
    volatile *u32 gpio_odr   = @inttoptr(*u32, 0x40024014);
    volatile *u32 gpio_idr   = @inttoptr(*u32, 0x40024010);

    // Read-modify-write on mode register
    u32 mode = gpio_moder[0];
    mode = mode | 1;
    gpio_moder[0] = mode;

    // Set output bit
    gpio_odr[0] = 32;

    // Read input (value discarded — just exercising the read path)
    u32 v = gpio_idr[0];
    if (v == 0xFFFFFFFF) { return 99; } // make v observable; never true on QEMU

    return 0;
}
