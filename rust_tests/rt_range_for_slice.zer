// Range-based for — iterate over slice elements.

struct Point { u32 x; u32 y; }

i32 main() {
    u32[5] arr;
    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    arr[3] = 40;
    arr[4] = 50;

    // Convert to slice
    [*]u32 slice = arr;

    // Range-based for: for (Type item in slice) { }
    u32 total = 0;
    for (u32 val in slice) {
        total += val;
    }
    // 10+20+30+40+50 = 150
    if (total != 150) { return 1; }

    return 0;
}
