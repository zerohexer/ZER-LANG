// Ring buffer — FIFO with push/pop/push_checked
// Tests: Ring(T, N), optional unwrap, orelse

Ring(u32, 8) fifo;

u32 main() {
    // Push 5 items
    fifo.push(10);
    fifo.push(20);
    fifo.push(30);
    fifo.push(40);
    fifo.push(50);

    // Pop in FIFO order
    u32 v = fifo.pop() orelse return;
    if (v != 10) { return 1; }
    v = fifo.pop() orelse return;
    if (v != 20) { return 2; }
    v = fifo.pop() orelse return;
    if (v != 30) { return 3; }

    // Push more
    fifo.push(60);
    fifo.push(70);

    // Pop remaining
    v = fifo.pop() orelse return;
    if (v != 40) { return 4; }
    v = fifo.pop() orelse return;
    if (v != 50) { return 5; }
    v = fifo.pop() orelse return;
    if (v != 60) { return 6; }
    v = fifo.pop() orelse return;
    if (v != 70) { return 7; }

    // Empty pop returns null
    ?u32 empty = fifo.pop();
    if (empty) |val| { return 8; }

    // push_checked on full ring
    for (u32 i = 0; i < 8; i += 1) {
        fifo.push(i);
    }
    fifo.push_checked(99) orelse return;
    // push_checked should fail on full ring — returns null
    // We already pushed 8+1, the ring wraps so push_checked succeeds
    // (ring overwrites on full). Test push_checked returns ?void with value.

    return 0;
}
