// Critical: MAYBE_FREED in loop — free in loop body, use next iteration
// EXPECTED: compile error

struct Item { u32 id; }
Pool(Item, 4) pool;

u32 main() {
    ?Handle(Item) mh = pool.alloc();
    Handle(Item) h = mh orelse return;
    pool.get(h).id = 1;

    for (u32 i = 0; i < 3; i += 1) {
        pool.get(h).id = i;
        if (i == 1) {
            pool.free(h);
        }
    }
    return 0;
}
