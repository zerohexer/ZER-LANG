// Rust: Arc<Mutex<u32>> shared between threads
// ZER: shared struct — auto-locked, no Arc/Mutex boilerplate

shared struct Counter { u32 value; }
Counter g;

void increment(*Counter c) {
    c.value += 1;
}

u32 main() {
    g.value = 0;
    // Multiple spawns sharing same counter — all auto-locked
    spawn increment(&g);
    spawn increment(&g);
    spawn increment(&g);
    // Main also increments — auto-locked
    g.value += 1;
    return 0;
}
