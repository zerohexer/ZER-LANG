// Handle: Task.new() auto-slab allocation

struct Task { u32 id; u32 state; }

u32 main() {
    ?Handle(Task) mh = Task.new();
    Handle(Task) h = mh orelse return;

    pool_of_task: {
        h.id = 1;
        h.state = 0;
    }

    u32 id = h.id;
    u32 st = h.state;
    Task.delete(h);

    if (id != 1) { return 1; }
    if (st != 0) { return 2; }
    return 0;
}
