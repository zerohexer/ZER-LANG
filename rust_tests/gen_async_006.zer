// Async: producer-consumer via global flag + yield

u32 produced;
u32 consumed;
u32 ready;

async void producer() {
    produced = 42;
    ready = 1;
    yield;
    produced = 99;
    ready = 1;
}

async void consumer() {
    while (ready == 0) { yield; }
    consumed = produced;
    ready = 0;
}

u32 main() {
    produced = 0;
    consumed = 0;
    ready = 0;

    _zer_async_producer p;
    _zer_async_consumer c;
    _zer_async_producer_init(&p);
    _zer_async_consumer_init(&c);

    _zer_async_producer_poll(&p);
    _zer_async_consumer_poll(&c);
    _zer_async_consumer_poll(&c);

    if (consumed != 42) { return 1; }
    return 0;
}
