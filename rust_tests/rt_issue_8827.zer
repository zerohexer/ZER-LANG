// Rust source: tests/ui/threads-sendsync/issue-8827.rs
// Safety scenario: FizzBuzz with concurrent producers.
// Rust: 3 channel-producing threads (fizz, buzz, fizzbuzz).
// ZER: 3 threads classify ranges concurrently, results in shared struct.

shared struct Results {
    u32 fizz_count;
    u32 buzz_count;
    u32 fizzbuzz_count;
}

Results res;

void classify_range(*Results r, u32 start, u32 end) {
    u32 i = start;
    while (i <= end) {
        u32 f = i % 3;
        u32 b = i % 5;
        if (f == 0 && b == 0) {
            r.fizzbuzz_count = r.fizzbuzz_count + 1;
        } else if (f == 0) {
            r.fizz_count = r.fizz_count + 1;
        } else if (b == 0) {
            r.buzz_count = r.buzz_count + 1;
        }
        i += 1;
    }
}

u32 main() {
    res.fizz_count = 0;
    res.buzz_count = 0;
    res.fizzbuzz_count = 0;

    // 3 threads each classify a range of 1..15
    ThreadHandle t1 = spawn classify_range(&res, 1, 5);
    ThreadHandle t2 = spawn classify_range(&res, 6, 10);
    ThreadHandle t3 = spawn classify_range(&res, 11, 15);

    t1.join();
    t2.join();
    t3.join();

    // Over 1..15: fizzbuzz=1 (15), fizz=4 (3,6,9,12), buzz=2 (5,10)
    if (res.fizzbuzz_count != 1) { return 1; }
    if (res.fizz_count != 4) { return 2; }
    if (res.buzz_count != 2) { return 3; }
    return 0;
}
