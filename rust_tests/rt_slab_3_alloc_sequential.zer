// Rust pattern: 3 sequential Box allocs, each used independently.

struct Node { u32 id; u32 next; }
Slab(Node) heap;

u32 main() {
    ?*Node m1 = heap.alloc_ptr();
    *Node n1 = m1 orelse return;
    defer heap.free_ptr(n1);
    n1.id = 1;
    n1.next = 0;

    ?*Node m2 = heap.alloc_ptr();
    *Node n2 = m2 orelse return;
    defer heap.free_ptr(n2);
    n2.id = 2;
    n2.next = 0;

    ?*Node m3 = heap.alloc_ptr();
    *Node n3 = m3 orelse return;
    defer heap.free_ptr(n3);
    n3.id = 3;
    n3.next = 0;

    u32 sum = n1.id + n2.id + n3.id;
    if (sum != 6) { return 1; }
    return 0;
}
