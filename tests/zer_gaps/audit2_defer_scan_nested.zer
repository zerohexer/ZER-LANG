Slab(Task) heap;

u32 main() {
    *Task t = Task.alloc_ptr() orelse return;
    bool c = true;
    if (c) { if (c) { if (c) { if (c) { if (c) { if (c) { if (c) { if (c) {
    if (c) { if (c) { if (c) { if (c) { if (c) { if (c) { if (c) { if (c) {
    if (c) { if (c) { if (c) { if (c) { if (c) { if (c) { if (c) { if (c) {
    if (c) { if (c) { if (c) { if (c) { if (c) { if (c) { if (c) { if (c) {
        defer heap.free_ptr(t);
        u32 x = t.id;
        return x;
    }}}}}}}}
    }}}}}}}}
    }}}}}}}}
    }}}}}}}}
    return 0;
}
