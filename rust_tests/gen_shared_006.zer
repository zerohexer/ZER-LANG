// Shared struct: scoped spawn with join — safe with ThreadHandle

shared struct Accum { u32 total; }
Accum g_accum;

void add_ten() {
    g_accum.total += 10;
}

u32 main() {
    g_accum.total = 0;
    ThreadHandle th = spawn add_ten();
    th.join();
    if (g_accum.total != 10) { return 1; }
    return 0;
}
