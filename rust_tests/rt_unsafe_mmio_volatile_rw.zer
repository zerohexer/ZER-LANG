// Rust unsafe: volatile read-modify-write to MMIO register.
// ZER: volatile pointer from @inttoptr with declared mmio range.
// Tests MMIO declaration + volatile pointer + bit manipulation.

mmio 0x40020000..0x40020FFF;

i32 main() {
    volatile *u32 gpio_odr = @inttoptr(*u32, 0x40020014);
    // Read-modify-write: set bit 5
    u32 val = gpio_odr[0];
    val = val | 32;
    gpio_odr[0] = val;
    return 0;
}
