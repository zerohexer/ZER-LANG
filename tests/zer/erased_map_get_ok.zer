// PART 6 (erased-ref ownership, Increment 1): a GLib-GHashTable-style generic
// map storing *opaque VALUES must compile — map_get returns a CONTENT borrow
// (`m.slots[i].value`, a value stored in the param), NOT a fresh allocation and
// NOT a param-view. So ret_is_borrow(map_get)=true AND ret_is_content=true →
// the caller leak-suppresses the result (no false "ghost handle / never freed").
// Contrast rt_drop_conflict_uaf: `return &s.field` is a param-VIEW
// (ret_is_content=false) → stays tracked. Must compile + run + exit 0.

u32 djb2(const [*]u8 s) {
    u32 h = 5381;
    for (u32 i = 0; i < s.len; i += 1) { h = (h * 33) + (u32)s[i]; }
    return h;
}
bool bytes_eq(const [*]u8 a, const [*]u8 b) {
    if (a.len != b.len) { return false; }
    for (u32 i = 0; i < a.len; i += 1) { if (a[i] != b[i]) { return false; } }
    return true;
}

struct Entry { const [*]u8 key; *opaque value; bool used; }
struct Map {
    *(const [*]u8) -> u32 hash_fn;
    *(const [*]u8, const [*]u8) -> bool eq_fn;
    Entry[64] slots;
}

void map_init(*Map m) { m.hash_fn = djb2; m.eq_fn = bytes_eq; }

void map_put(*Map m, const [*]u8 key, *opaque value) {
    u32 idx = m.hash_fn(key) % 64;
    for (u32 i = 0; i < 64; i += 1) {
        u32 slot = (idx + i) % 64;
        if (!m.slots[slot].used) {
            m.slots[slot].key = key;
            m.slots[slot].value = value;
            m.slots[slot].used = true;
            return;
        }
        if (m.eq_fn(m.slots[slot].key, key)) { m.slots[slot].value = value; return; }
    }
}
?*opaque map_get(*Map m, const [*]u8 key) {
    u32 idx = m.hash_fn(key) % 64;
    for (u32 i = 0; i < 64; i += 1) {
        u32 slot = (idx + i) % 64;
        if (!m.slots[slot].used) { return null; }
        if (m.eq_fn(m.slots[slot].key, key)) { return m.slots[slot].value; }
    }
    return null;
}

struct Box { u32 v; }
Box g_a;
Box g_b;

u32 main() {
    g_a.v = 111;
    g_b.v = 222;
    Map m;
    map_init(&m);
    map_put(&m, "A12", (*opaque)&g_a);
    map_put(&m, "B34", (*opaque)&g_b);

    *opaque raw = map_get(&m, "A12") orelse { return 1; };
    *Box pb = (*Box)raw;
    if (pb.v != 111) { return 2; }

    *opaque raw2 = map_get(&m, "B34") orelse { return 3; };
    *Box pb2 = (*Box)raw2;
    if (pb2.v != 222) { return 4; }
    return 0;
}
