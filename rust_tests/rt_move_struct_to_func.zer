// Rust pattern: move struct to function, original invalid.
// ZER: pass handle to function that frees it.

struct Msg { u32 code; u32 data; }
Pool(Msg, 4) pool;

void consume(Handle(Msg) h) {
    u32 code = pool.get(h).code;
    pool.free(h);
}

u32 main() {
    ?Handle(Msg) mm = pool.alloc();
    Handle(Msg) h = mm orelse return;
    pool.get(h).code = 42;
    pool.get(h).data = 100;

    consume(h);
    // h is consumed (freed by consume) — we don't use it again
    return 0;
}
