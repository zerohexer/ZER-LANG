// Rust: vec-overrun.rs — runtime bounds check panic
// ZER: auto-guard catches unprovable index at runtime (returns zero value)
// ZER is BETTER: no panic, graceful handling

u32[3] arr;

u32 main() {
    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    u32 idx = 1;
    u32 val = arr[idx];
    if (val != 20) { return 1; }
    return 0;
}
