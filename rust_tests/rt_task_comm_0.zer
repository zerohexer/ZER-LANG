// Rust source: tests/ui/threads-sendsync/task-comm-0.rs
// Thread sends 10, 20, 30 through channel. Main receives all 3, asserts last == 30.

struct Msg { u32 value; }

Ring(Msg, 16) chan;

shared struct Flag { u32 done; }
Flag flag;

void producer(*Flag f) {
    Msg m1; m1.value = 10; chan.push(m1);
    Msg m2; m2.value = 20; chan.push(m2);
    Msg m3; m3.value = 30; chan.push(m3);
    f.done = 1;
    @cond_signal(f);
}

u32 main() {
    flag.done = 0;
    ThreadHandle th = spawn producer(&flag);
    @cond_wait(flag, flag.done > 0);
    th.join();

    ?Msg r1 = chan.pop();
    Msg v1 = r1 orelse return;

    ?Msg r2 = chan.pop();
    Msg v2 = r2 orelse return;

    ?Msg r3 = chan.pop();
    Msg v3 = r3 orelse return;

    if (v1.value != 10) { return 1; }
    if (v2.value != 20) { return 2; }
    if (v3.value != 30) { return 3; }
    return 0;
}
