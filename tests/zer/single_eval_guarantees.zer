// BUG-567/568/569: single-eval guarantees — side-effect expressions must
// be called exactly the number of times the source says, not more.

u32 counter = 0;

?u32 next() { counter = counter + 1; return counter; }
u32 start_side() { counter = counter + 1; return 1; }
u32 end_side() { counter = counter + 1; return 3; }

u32 test_orelse_index() {
    // BUG-567: arr[next() orelse 0] — next() exactly once.
    counter = 0;
    u32[4] arr;
    arr[0] = 10; arr[1] = 20; arr[2] = 30; arr[3] = 40;
    u32 x = arr[next() orelse 0];
    // counter=1, arr[1]=20, total = 21.
    return x + counter;
}

u32 test_slice_single_eval() {
    // BUG-568: arr[start()..end()] — each called exactly once.
    counter = 0;
    u32[5] arr;
    arr[0] = 10; arr[1] = 20; arr[2] = 30; arr[3] = 40; arr[4] = 50;
    []u32 s = arr[start_side()..end_side()];
    // counter = 2 (not 3 or 4).
    return counter;
}

u32 main() {
    if (test_orelse_index() != 21) { return 1; }
    if (test_slice_single_eval() != 2) { return 2; }
    return 0;
}
