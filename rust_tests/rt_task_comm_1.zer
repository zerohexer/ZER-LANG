// Rust source: tests/ui/threads-sendsync/task-comm-1.rs
// Safety scenario: spawn thread, join it, verify it ran to completion.
// Thread ownership: thread runs independently, join proves it finished.
// ZER: ThreadHandle th = spawn start(); th.join();

shared struct Done {
    u32 flag;
}

Done gdone;

void start(*Done d) {
    d.flag = 1;
}

u32 main() {
    gdone.flag = 0;

    ThreadHandle th = spawn start(&gdone);
    th.join();

    u32 v = gdone.flag;
    if (v != 1) { return 1; }
    return 0;
}
