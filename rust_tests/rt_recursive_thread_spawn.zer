// Rust source: tests/ui/threads-sendsync/recursive-thread-spawn.rs
// 1024+ recursive thread spawns. Each spawns the next.
// ZER: recursive spawn with ThreadHandle+join — depth 20.
// (Rust does 1457 — we use 20 to avoid stack/thread exhaustion in Docker)

shared struct Counter { u32 n; }
Counter ctr;

void recursive_worker(*Counter c, u32 depth) {
    c.n = c.n + 1;
    if (depth > 0) {
        ThreadHandle th = spawn recursive_worker(c, depth - 1);
        th.join();
    }
}

u32 main() {
    ctr.n = 0;
    ThreadHandle th = spawn recursive_worker(&ctr, 20);
    th.join();

    if (ctr.n != 21) { return 1; }
    return 0;
}
