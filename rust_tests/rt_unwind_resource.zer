// Rust source: tests/ui/threads-sendsync/unwind-resource.rs
// Drop handler runs during panic (cleanup). Thread sends true before unwind.
// ZER: Thread with defer cleanup. defer sets a shared flag. Main verifies flag set.

shared struct CleanupFlag {
    u32 cleaned;
}

CleanupFlag flag;

void worker(*CleanupFlag f) {
    // defer simulates Drop — runs on all exit paths including early return (panic analog)
    defer {
        f.cleaned = 1;
        @cond_signal(f);
    }
    // Simulate some work then early exit (like panic unwind)
    return;
}

u32 main() {
    flag.cleaned = 0;

    ThreadHandle th = spawn worker(&flag);
    @cond_wait(flag, flag.cleaned > 0);
    th.join();

    u32 c = flag.cleaned;
    if (c != 1) { return 1; }
    return 0;
}
