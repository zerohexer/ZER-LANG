// Shared struct: read-write lock with shared(rw)

shared(rw) struct Cache { u32 hits; u32 misses; }
Cache g_cache;

u32 get_hits() {
    return g_cache.hits;
}

void record_hit() {
    g_cache.hits += 1;
}

u32 main() {
    g_cache.hits = 0;
    g_cache.misses = 0;
    record_hit();
    record_hit();
    record_hit();
    u32 h = get_hits();
    if (h != 3) { return 1; }
    return 0;
}
