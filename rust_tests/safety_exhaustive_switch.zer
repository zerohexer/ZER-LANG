// Rust: non-exhaustive match on enum — compile error
// ZER: exhaustive switch on enum — compile error if case missing
// This test covers ALL variants so it should PASS

enum Color { red, green, blue }

u32 main() {
    Color c = Color.green;
    u32 result = 0;
    switch (c) {
        .red => { result = 1; }
        .green => { result = 2; }
        .blue => { result = 3; }
    }
    if (result != 2) { return 1; }
    return 0;
}
