// BUG-579 — while + continue inside switch arm
enum Mode { sum_odd, sum_all }

u32 main() {
    Mode m = Mode.sum_odd;
    u32 total = 0;
    u32 i = 0;
    switch (m) {
        .sum_odd => {
            while (i < 10) {
                i += 1;
                if (i % 2 == 0) { continue; }
                total += i;
            }
        }
        .sum_all => {
            while (i < 10) {
                i += 1;
                total += i;
            }
        }
    }
    // i=1,3,5,7,9 → 25
    if (total != 25) { return 1; }
    return 0;
}
