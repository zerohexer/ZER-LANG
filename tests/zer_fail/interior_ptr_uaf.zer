// Interior pointer UAF — &b.field used after free_ptr(b)
// zercheck must catch: field_ptr is derived from b, same alloc_id

struct Block { u32 a; u32 b; u32 c; }
Slab(Block) heap;

u32 main() {
    ?*Block mb = heap.alloc_ptr();
    *Block b = mb orelse return;
    b.c = 42;
    *u32 field_ptr = &b.c;
    heap.free_ptr(b);
    u32 val = field_ptr[0];
    return val;
}
