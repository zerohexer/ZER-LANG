// async/await: stackless coroutines via Duff's device state machine
// Zero heap, zero runtime, one struct per task

u32 total;
u32 done_flag;

async void accumulate() {
    u32 sum = 0;
    u32 count = 0;
    while (count < 5) {
        sum += count;
        count += 1;
        yield;
    }
    total = sum;
    done_flag = 1;
}

u32 main() {
    total = 0;
    done_flag = 0;
    _zer_async_accumulate task;
    _zer_async_accumulate_init(&task);
    // Poll until coroutine signals done
    while (done_flag == 0) {
        _zer_async_accumulate_poll(&task);
    }
    // sum = 0 + 1 + 2 + 3 + 4 = 10
    if (total != 10) { return 1; }
    return 0;
}
