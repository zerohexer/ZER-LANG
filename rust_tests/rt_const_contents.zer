// Rust source: tests/ui/consts/const-contents.rs
// Static constants evaluated at compile time.
// ZER: const globals with shift, add, negation — all pre-evaluated

const u32 LSL = 1 << 2;
const u32 ADD = 1 + 2;
const i32 NEG = -(1);

u32 main() {
    if (LSL != 4) { return 1; }
    if (ADD != 3) { return 2; }
    if (NEG != -1) { return 3; }
    return 0;
}
