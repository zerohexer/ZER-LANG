// EXPECTED: compile error
// keep axis, struct-copy launder (hole A, 2026-06-07): a non-keep pointer param
// stored into a LOCAL struct's field, then the whole struct copied to a global,
// persists the borrow into the global (dangles when the caller's pointee dies).
// The struct inherits is_nonkeep_derived via the field store; the persist check
// now fires on STRUCT/UNION values, not just bare pointers. Fix: `keep *u32 p`.
struct Box { ?*u32 slot; }
Box g_box;
void stash(*u32 p) {
    Box local;
    local.slot = p;
    g_box = local;
}
i32 main() { return 0; }
