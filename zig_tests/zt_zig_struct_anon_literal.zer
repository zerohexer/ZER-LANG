// Translated from: zig/test/behavior/struct.zig — "anonymous struct literal syntax"
// Zig: var p: Point = .{ .x = 1, .y = 2 };

struct Point { i32 x; i32 y; }

i32 main() {
    Point p = { .x = 1, .y = 2 };
    if (p.x != 1) { return 1; }
    if (p.y != 2) { return 2; }

    p = { .x = 10, .y = 20 };
    if (p.x != 10) { return 3; }
    if (p.y != 20) { return 4; }
    return 0;
}
