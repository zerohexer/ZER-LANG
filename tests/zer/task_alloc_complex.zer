// Complex: multiple struct types with Task.alloc(), mixed Handle + ptr

struct Task {
    u32 id;
    u32 priority;
}

struct Node {
    u32 value;
    u32 depth;
}

u32 main() {
    // Two different types — auto-creates two separate slabs
    Handle(Task) t = Task.alloc() orelse { return 1; };
    Handle(Node) n = Node.alloc() orelse { return 2; };

    t.id = 10;
    t.priority = 3;
    n.value = 99;
    n.depth = 5;

    if (t.id != 10) { return 3; }
    if (n.value != 99) { return 4; }
    if (n.depth != 5) { return 5; }

    // Mix Handle and ptr on same type
    *Task t2 = Task.alloc_ptr() orelse { return 6; };
    t2.id = 77;
    if (t2.id != 77) { return 7; }

    Task.free(t);
    Node.free(n);
    Task.free_ptr(t2);

    return 0;
}
