// BUG-418: else-if chain #line directive causes GCC "stray #" error
// Tests: else if with source mapping enabled

u32 classify(u32 x) {
    if (x < 10) {
        return 1;
    } else if (x < 20) {
        return 2;
    } else if (x < 50) {
        return 3;
    } else if (x < 100) {
        return 4;
    } else {
        return 5;
    }
}

u32 main() {
    if (classify(5) != 1) { return 1; }
    if (classify(15) != 2) { return 2; }
    if (classify(42) != 3) { return 3; }
    if (classify(75) != 4) { return 4; }
    if (classify(200) != 5) { return 5; }
    return 0;
}
