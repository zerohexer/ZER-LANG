// Rust equivalent: recursive struct with optional self-reference
// Linked list node with ?*Node next field

struct ListNode {
    u32 value;
    ?*ListNode next;
}

Slab(ListNode) heap;

u32 main() {
    // Build: 3 → 2 → 1 → null
    ?*ListNode m1 = heap.alloc_ptr();
    *ListNode n1 = m1 orelse return;
    n1.value = 1;
    n1.next = null;

    ?*ListNode m2 = heap.alloc_ptr();
    *ListNode n2 = m2 orelse return;
    n2.value = 2;
    n2.next = n1;

    ?*ListNode m3 = heap.alloc_ptr();
    *ListNode n3 = m3 orelse return;
    n3.value = 3;
    n3.next = n2;

    // Walk and sum
    u32 sum = 0;
    ?*ListNode current = n3;
    bool running = true;
    while (running) {
        if (current) |node| {
            sum += node.value;
            current = node.next;
        } else {
            running = false;
        }
    }

    // Cleanup
    heap.free_ptr(n3);
    heap.free_ptr(n2);
    heap.free_ptr(n1);

    if (sum != 6) { return 1; }
    return 0;
}
