// Audit 2026-05-26: static local initializer was silently dropped on the
// IR path. ir_lower emitted the local but skipped lowering the init,
// and emitter unconditionally emitted `static T name = {0};`. Result:
// `static u32 retries = 3;` got `retries == 0` on every call.
//
// Fix: ir_lower stores init on IRLocal.static_init; emitter emits it
// inline via emit_rewritten_node.

i32 puts(const *u8 s);

u32 get_static() {
    static u32 retries = 3;
    return retries;
}

u32 get_static_const() {
    const u32 EXPECTED = 42;
    static u32 value = 42;
    return value;
}

i32 main() {
    u32 a = get_static();
    if (a != 3) { puts("FAIL: static u32 init dropped"); return 1; }
    u32 b = get_static_const();
    if (b != 42) { puts("FAIL: static u32 const init dropped"); return 2; }
    puts("OK");
    return 0;
}
