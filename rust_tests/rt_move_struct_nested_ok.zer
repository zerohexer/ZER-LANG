// Move struct containing another move struct — both transferred together.
// Rust: struct Outer(Inner) where Inner: not Copy

move struct Inner { u32 val; }
move struct Outer { Inner inner; u32 id; }

void consume_outer(Outer o) {
    u32 x = o.id;
}

i32 main() {
    Outer o;
    o.inner.val = 7;
    o.id = 99;
    if (o.id != 99) { return 1; }
    consume_outer(o);   // both outer and inner transferred
    return 0;
}
