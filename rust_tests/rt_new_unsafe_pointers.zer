// Rust source: tests/ui/unsafe/new-unsafe-pointers.rs
// Cast integer to pointer (raw pointer creation).
// ZER: @inttoptr with mmio declaration.

mmio 0x0..0xFFFFFFFF;

u32 main() {
    volatile *u32 p = @inttoptr(*u32, 0x1000);
    // Just verify it compiles — we can't actually deref without real hardware
    return 0;
}
