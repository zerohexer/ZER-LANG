// Null safety: optional value — if-unwrap pattern safe

u32 try_get(bool succeed) {
    if (succeed) {
        ?u32 result = (u32)42;
        return result orelse 0;
    }
    ?u32 empty;
    return empty orelse 99;
}

u32 main() {
    u32 v1 = try_get(true);
    if (v1 != 42) { return 1; }
    u32 v2 = try_get(false);
    if (v2 != 99) { return 2; }
    return 0;
}
