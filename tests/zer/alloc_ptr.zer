// alloc_ptr: *Task from Slab — direct pointer, zercheck tracked

struct Task {
    u32 id;
    u32 priority;
}

Slab(Task) heap;

u32 main() {
    // alloc_ptr returns ?*Task (null sentinel)
    *Task t = heap.alloc_ptr() orelse { return 1; };
    t.id = 42;
    t.priority = 3;

    *Task t2 = heap.alloc_ptr() orelse { return 2; };
    t2.id = 99;

    // verify values
    if (t.id != 42) { return 3; }
    if (t.priority != 3) { return 4; }
    if (t2.id != 99) { return 5; }

    // free
    heap.free_ptr(t);
    heap.free_ptr(t2);

    return 0;
}
