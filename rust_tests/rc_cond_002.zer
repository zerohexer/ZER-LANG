// Rust: Condvar::notify_all — broadcast wakes multiple waiters
// ZER: @cond_broadcast wakes all waiting threads
// Equivalent to: Rust Condvar::notify_all pattern

shared struct Gate {
    u32 open;
    u32 passed;
}

Gate ggate;

void waiter(*Gate g) {
    @cond_wait(g, g.open > 0);
    g.passed += 1;
}

u32 main() {
    ggate.open = 0;
    ggate.passed = 0;

    ThreadHandle t1 = spawn waiter(&ggate);
    ThreadHandle t2 = spawn waiter(&ggate);
    ThreadHandle t3 = spawn waiter(&ggate);

    // Small pause via busy-wait on passed still zero (threads start)
    // Then open the gate
    ggate.open = 1;
    @cond_broadcast(ggate);

    t1.join();
    t2.join();
    t3.join();

    u32 p = ggate.passed;
    if (p != 3) { return 1; }
    return 0;
}
