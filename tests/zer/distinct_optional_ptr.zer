// distinct typedef ?*T — null check must use null sentinel, not .has_value
// Also: distinct ?void bare return must emit { 1 } not { 0, 1 }

struct Data { u32 x; }

distinct typedef ?void Result;

Result do_work() {
    return;
}

Result do_fail() {
    return null;
}

u32 main() {
    // distinct ?void bare return
    Result r = do_work();
    Result r2 = do_fail();
    return 0;
}
