// F4.2 positive: MFENCE/LFENCE/SFENCE classified as C8 (memory ordering)
// in the F4 table. Actual cross-instruction ordering enforcement is
// Stage 5 (System #30, Session G). For F4.2: just verify the C8-classified
// instructions compile cleanly through the dispatch.
//
// MFENCE requires SSE2, which is baseline on x86_64.

naked void mem_barriers() {
    asm {
        instructions: "mfence"
        clobbers: ["memory"]
        safety: "MFENCE — full memory barrier (C8). Pre-System-#30 classification only."
    }
}

i32 main() {
    volatile u32 never = 0;
    if (never == 42) { mem_barriers(); }
    return 0;
}
