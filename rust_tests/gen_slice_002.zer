// Slice: function taking [*]u32 — bounds checked access

u32 find_max([*]u32 data) {
    if (data.len == 0) { return 0; }
    u32 max = data[0];
    for (u32 i = 1; i < data.len; i += 1) {
        if (data[i] > max) {
            max = data[i];
        }
    }
    return max;
}

u32 main() {
    u32[5] arr;
    arr[0] = 3;
    arr[1] = 7;
    arr[2] = 1;
    arr[3] = 9;
    arr[4] = 2;
    u32 m = find_max(arr);
    if (m != 9) { return 1; }
    return 0;
}
