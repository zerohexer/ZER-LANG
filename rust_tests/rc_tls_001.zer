// Rust: thread_local! — each thread has independent counter
// ZER: threadlocal — __thread ensures per-thread storage
// Equivalent to: Rust thread_local! basic isolation test

threadlocal u32 tls_val;

shared struct Collected {
    u32 sum;
}

Collected gcol;

void worker_thread(*Collected c, u32 init_val) {
    tls_val = init_val;
    // Each thread's tls_val is independent
    tls_val *= 2;
    c.sum += tls_val;
}

u32 main() {
    gcol.sum = 0;

    ThreadHandle t1 = spawn worker_thread(&gcol, 5);
    ThreadHandle t2 = spawn worker_thread(&gcol, 10);
    ThreadHandle t3 = spawn worker_thread(&gcol, 15);

    t1.join();
    t2.join();
    t3.join();

    // t1: 5*2=10, t2: 10*2=20, t3: 15*2=30 → sum = 60
    u32 s = gcol.sum;
    if (s != 60) { return 1; }
    return 0;
}
