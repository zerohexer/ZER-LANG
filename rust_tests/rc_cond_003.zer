// Rust: Condvar — wait for counter to reach threshold
// ZER: @cond_wait with counter increment condition
// Equivalent to: Rust Condvar::wait_while pattern

shared struct CondBarrier {
    u32 count;
    u32 target;
}

CondBarrier gbar;

void increment_and_signal(*CondBarrier b) {
    b.count += 1;
    @cond_signal(b);
}

u32 main() {
    gbar.count = 0;
    gbar.target = 3;

    ThreadHandle t1 = spawn increment_and_signal(&gbar);
    ThreadHandle t2 = spawn increment_and_signal(&gbar);
    ThreadHandle t3 = spawn increment_and_signal(&gbar);

    @cond_wait(gbar, gbar.count >= gbar.target);

    t1.join();
    t2.join();
    t3.join();

    u32 c = gbar.count;
    if (c != 3) { return 1; }
    return 0;
}
