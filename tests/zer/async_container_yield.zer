// Async + container(T) local with yield — container struct promoted to state struct

container Pair(T) {
    T first;
    T second;
}

async void make_pair() {
    Pair(u32) p;
    p.first = 10;
    yield;
    p.second = 20;
    yield;
    if (p.first + p.second != 30) { return; }
}

u32 main() {
    _zer_async_make_pair task;
    _zer_async_make_pair_init(&task);
    i32 r1 = _zer_async_make_pair_poll(&task);
    if (r1 != 0) { return 1; }
    i32 r2 = _zer_async_make_pair_poll(&task);
    if (r2 != 0) { return 2; }
    i32 r3 = _zer_async_make_pair_poll(&task);
    if (r3 != 1) { return 3; }
    return 0;
}
