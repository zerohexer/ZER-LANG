// Range-for on fixed array — array.len emitted as size literal (BUG-501)
struct Item { u32 val; }
u32 main() {
    Item[3] arr;
    arr[0].val = 10;
    arr[1].val = 20;
    arr[2].val = 30;
    u32 total = 0;
    for (Item it in arr) {
        total += it.val;
    }
    if (total != 60) { return 1; }
    return 0;
}
