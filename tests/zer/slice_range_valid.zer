// Regression guard: valid slice subrange arr[a..b] where a <= b
// computes correct length. Pairs with tests/zer_trap/slice_range_underflow_trap.zer.

u32 sum_range(u32 lo, u32 hi) {
    u32[10] arr;
    arr[2] = 100;
    arr[3] = 200;
    arr[4] = 300;
    [*]u32 s = arr[lo..hi];
    u32 total = 0;
    for (u32 i = 0; i < s.len; i += 1) {
        total += s[i];
    }
    return total;
}

u32 main() {
    // lo=2, hi=5 → slice is [100, 200, 300, 0], len=3 elements (indices 2..4)
    u32 r = sum_range(2, 5);
    if (r != 600) { return 1; }
    return 0;
}
