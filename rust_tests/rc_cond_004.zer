// Rust: Condvar — loop with predicate re-check (spurious wakeup safe)
// ZER: @cond_wait loop pattern — condition rechecked automatically
// Equivalent to: Rust Condvar::wait_while with while loop

shared struct Queue {
    u32[8] items;
    u32 head;
    u32 tail;
    u32 count;
}

Queue gq;

void enqueue(*Queue q, u32 val) {
    q.items[q.tail] = val;
    q.tail = (q.tail + 1) % 8;
    q.count += 1;
    @cond_signal(q);
}

u32 main() {
    gq.head = 0;
    gq.tail = 0;
    gq.count = 0;

    ThreadHandle t1 = spawn enqueue(&gq, 10);
    ThreadHandle t2 = spawn enqueue(&gq, 20);
    ThreadHandle t3 = spawn enqueue(&gq, 30);

    // Wait until three items are available
    @cond_wait(gq, gq.count >= 3);

    t1.join();
    t2.join();
    t3.join();

    u32 sum = 0;
    u32 i = 0;
    while (i < 3) {
        sum += gq.items[i];
        i += 1;
    }

    if (sum != 60) { return 1; }
    return 0;
}
