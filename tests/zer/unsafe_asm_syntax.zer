// `unsafe asm` is the required form for inline assembly (2026-04-23).
// Bare `asm(...)` is rejected — users must explicitly mark the escape hatch.
// Phase 1 verified: zer_asm_allowed_in_context enforces naked-function restriction.

naked void isr_one() {
    unsafe asm("nop");
}

naked void isr_two() {
    unsafe asm("nop");
    unsafe asm("nop");
}

i32 main() {
    return 0;
}
