// Rust: Drop trait — automatic cleanup on scope exit
// ZER: defer — explicit cleanup on ALL exit paths (return, break, etc.)

struct Buffer { u32 size; }
Slab(Buffer) heap;

u32 process(bool fail) {
    ?*Buffer mb = heap.alloc_ptr();
    *Buffer buf = mb orelse return;
    defer heap.free_ptr(buf);

    buf.size = 100;
    if (fail) {
        return 1;
    }
    return 0;
}

u32 main() {
    u32 r1 = process(false);
    if (r1 != 0) { return 1; }

    u32 r2 = process(true);
    if (r2 != 1) { return 2; }

    return 0;
}
