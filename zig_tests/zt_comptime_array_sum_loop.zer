comptime u32 DOT_PRODUCT() {
    u32[3] a;
    u32[3] b;
    a[0] = 1; a[1] = 2; a[2] = 3;
    b[0] = 4; b[1] = 5; b[2] = 6;
    u32 sum = 0;
    for (u32 i = 0; i < 3; i += 1) {
        sum += a[i] * b[i];
    }
    return sum;
}

i32 main() {
    u32 d = DOT_PRODUCT();
    if (d != 32) { return 1; }
    return 0;
}
