// EXPECTED: compile error — F7 register name validation (O3 rule).
// "rax0" is a typo for "rax". The vendored x86_64 register table in
// src/safety/asm_register_tables_x86_64.c (generated by GCC probe via
// scripts/gen_register_tables.sh) does not contain "rax0", so the
// checker rejects it. This is the F7-minimum end-to-end validation
// of the F1a + F2 framework.

u64 g_result = 0;

naked void typo_register() {
    asm {
        instructions: "movq $42, %0"
        outputs: { "rax0" = g_result }   // typo — should be "rax"
        safety: "F7 test — typo'd register name should be caught by O3 rule"
    }
}

i32 main() { return 0; }
