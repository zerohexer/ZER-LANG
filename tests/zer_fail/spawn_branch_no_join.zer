// EXPECTED: compile error
// Axis-C / BUG-743: a scoped-spawn ThreadHandle created INSIDE a branch and
// never joined. Pre-fix, ir_merge_states unioned only handles[] and dropped
// threads[] from the non-first_live predecessor at the CFG merge, so the exit
// join-scan saw an empty threads[] and FALSE-GREENED this cross-thread
// stack-UAF (the spawned thread borrows &w, a stack local, and outlives it
// because the join obligation was silently dropped). Must now error.
struct Work { u32 task_id; u32 result; }

void compute(*Work w) {
    w.result = w.task_id * 10;
}

u32 main() {
    Work w;
    w.task_id = 7;
    w.result = 0;
    u32 cond = w.task_id;
    if (cond > 3) {
        ThreadHandle th = spawn compute(&w);
        // NOT joined — the borrow of &w outlives this scope
    }
    return 0;
}
