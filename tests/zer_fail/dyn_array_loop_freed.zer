// Loop free ALL elements — any post-loop access is compile error
struct Item { u32 val; }
Pool(Item, 8) pool;

u32 main() {
    Handle(Item)[4] handles;
    for (u32 i = 0; i < 4; i += 1) {
        ?Handle(Item) mh = pool.alloc();
        handles[i] = mh orelse return;
    }
    for (u32 i = 0; i < 4; i += 1) {
        pool.free(handles[i]);
    }
    // ALL freed in loop — compile error
    u32 idx = 0;
    u32 v = handles[idx].val;
    return v;
}
