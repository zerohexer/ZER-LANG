// Audit 2026-07-16: a non-loop var incremented in the for body was seen as its
// pre-loop range inside the body (for handler lacked the while/do-while
// vrp_invalidate_loop_body_writes pre-pass), proving arr[j] safe → the slice
// bounds check was elided → silent OOB write.
// Fix: for handler now runs the loop-body-writes pre-pass.
// Expected: SIGTRAP "array index out of bounds" at runtime.
u32 f() {
    [*]u32 arr = alloc(u32, 1) orelse { return 0; };
    u32 j = 0;
    for (u32 i = 0; i < 100; i += 1) {
        arr[j] = 7;
        j += 1;
    }
    free(arr);
    return 0;
}
u32 main() { return f(); }
