// Regression: `shared(rw) struct` cond evaluation emitted pthread_rwlock_wrlock
// instead of rdlock. Cause: emit_shared_lock_around_cond used make_inst default
// src2_local=-1 → emitter's `inst->src2_local != 0` saw true → write lock.
// Defeated shared(rw)'s reader concurrency entirely.
shared(rw) struct State { u32 v; }
State g;

u32 reader() {
    if (g.v > 0) { return 1; }
    return 0;
}

i32 main() {
    g.v = 5;
    u32 r = reader();
    if (r == 1) { return 0; }
    return 1;
}
