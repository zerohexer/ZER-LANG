// Phase D-Alpha-4: context switch intrinsics
// @cpu_save_context, @cpu_restore_context, @cpu_save_fpu, @cpu_restore_fpu
//
// These save/restore register state to a user-provided buffer. Not privileged
// on x86-64 (user-mode can execute fxsave/fxrstor), but register save/restore
// requires careful calling convention handling.
//
// Test: roundtrip save+restore should preserve state (no-op).

volatile u32 never_execute;   // 0 at startup

u64 test_ctx_roundtrip() {
    u8[128] ctx_buf;
    u8[512] fpu_buf;

    // Dead branch — compiler emits asm but never executes at runtime.
    // Guarantees compilation + link without risking register corruption
    // if the asm has subtle ABI issues.
    if (never_execute == 42) {
        @cpu_save_context(&ctx_buf[0]);
        @cpu_restore_context(&ctx_buf[0]);
        @cpu_save_fpu(&fpu_buf[0]);
        @cpu_restore_fpu(&fpu_buf[0]);
        return 1;
    }
    return 0;
}

i32 main() {
    u64 x = test_ctx_roundtrip();
    if (x != 0) { return 1; }
    return 0;
}
