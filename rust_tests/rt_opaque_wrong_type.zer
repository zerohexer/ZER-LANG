// Rust pattern: wrong downcast from dyn Any.
// ZER: @ptrcast to wrong type = compile error (provenance mismatch).
// EXPECTED: compile error

struct Dog { u32 tricks; }
struct Cat { u32 lives; }

u32 main() {
    Dog d;
    d.tricks = 5;

    *opaque raw = @ptrcast(*opaque, &d);

    // Cast back to WRONG type — provenance says Dog, casting to Cat
    *Cat wrong = @ptrcast(*Cat, raw);
    return wrong.lives;
}
