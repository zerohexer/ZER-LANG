// BUG-426: ! on integers (not just bool)
// Common pattern for comptime if (!FEATURE()) and C idioms

comptime u32 FEATURE_A() { return 1; }
comptime u32 FEATURE_B() { return 0; }

u32 main() {
    u32 result = 0;
    comptime if (!FEATURE_B()) {
        result = 42;
    }
    if (result != 42) { return 1; }

    comptime if (!FEATURE_A()) {
        result = 99;
    }
    if (result != 42) { return 2; }

    u32 x = 0;
    bool neg = !x;
    if (neg != true) { return 3; }

    u32 y = 5;
    bool neg2 = !y;
    if (neg2 != false) { return 4; }

    return 0;
}
