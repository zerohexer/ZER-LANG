// @once initialization runs exactly once.
// ZER semantic (matches Rust's `std::sync::Once`): each @once block declares
// its OWN one-shot flag. Repeated entries to the SAME @once block fire the
// body exactly once. Separate @once blocks are independent (would fire
// once each) — to test "once across repeated calls", wrap @once in a
// helper function and invoke it multiple times.

u32 init_count;

void do_init() {
    init_count += 1;
}

void try_init() {
    @once { do_init(); }
}

u32 main() {
    init_count = 0;
    try_init();
    try_init();
    try_init();
    if (init_count != 1) { return 1; }
    return 0;
}
