// Async orelse inside expression — yield+return exits safely
// (No yield-then-fallthrough, so no stale temp issue)
?u32 maybe_get() { return null; }
async void compute() {
    u32 x = maybe_get() orelse { return; };
}
u32 main() {
    _zer_async_compute task;
    _zer_async_compute_init(&task);
    _zer_async_compute_poll(&task);
    return 0;
}
