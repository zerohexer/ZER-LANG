// Shared: spawn with value args — copy, no sharing needed

shared struct Result { u32 sum; }
Result g_result;

void compute(u32 a, u32 b) {
    g_result.sum = a + b;
}

u32 main() {
    g_result.sum = 0;
    ThreadHandle th = spawn compute(10, 20);
    th.join();
    if (g_result.sum != 30) { return 1; }
    return 0;
}
