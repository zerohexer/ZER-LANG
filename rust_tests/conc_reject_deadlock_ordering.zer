// Rust equivalent: Mutex deadlock (ABBA pattern)
// ZER: detected at COMPILE TIME — same-statement multi-shared access.
// BUG-464: cross-statement ordering is safe (lock→op→unlock per statement).
// EXPECTED: compile error

shared struct AccountA { u32 balance; }
shared struct AccountB { u32 balance; }

AccountA a;
AccountB b;

// This function accesses BOTH in one expression — DEADLOCK RISK
void bad_transfer() {
    a.balance = b.balance + 100;  // ERROR: both AccountA and AccountB in one statement
}

u32 main() {
    a.balance = 1000;
    b.balance = 2000;
    return 0;
}
