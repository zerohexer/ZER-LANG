// Rust unsafe: multiple MMIO register accesses within declared range.
// ZER: mmio declaration + multiple volatile pointers from same range.

mmio 0x40020000..0x40020FFF;

i32 main() {
    volatile *u32 gpio_moder = @inttoptr(*u32, 0x40020000);
    volatile *u32 gpio_odr   = @inttoptr(*u32, 0x40020014);
    volatile *u32 gpio_idr   = @inttoptr(*u32, 0x40020010);

    // Read-modify-write on mode register
    u32 mode = gpio_moder[0];
    mode = mode | 1;
    gpio_moder[0] = mode;

    // Set output bit
    gpio_odr[0] = 32;

    return 0;
}
