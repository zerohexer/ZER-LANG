// Recursive: fibonacci — mutual recursion via single function

u32 fib(u32 n) {
    if (n < 2) { return n; }
    return fib(n - 1) + fib(n - 2);
}

u32 main() {
    if (fib(0) != 0) { return 1; }
    if (fib(1) != 1) { return 2; }
    if (fib(6) != 8) { return 3; }
    if (fib(10) != 55) { return 4; }
    return 0;
}
