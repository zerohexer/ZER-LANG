comptime u32 MAX_VARS() { return 8; }

enum OpCode { set, add, sub, mul, print, halt }

struct Instruction {
    OpCode op;
    u8 reg;
    u32 value;
}

u32 execute(Instruction[16] program, u32 prog_len) {
    u32[MAX_VARS()] regs;
    for (u32 i = 0; i < MAX_VARS(); i += 1) { regs[i] = 0; }

    u32 output = 0;
    for (u32 pc = 0; pc < prog_len; pc += 1) {
        Instruction inst = program[pc];
        u32 r = @truncate(u32, inst.reg);
        switch (inst.op) {
            .set => { regs[r] = inst.value; }
            .add => { regs[r] = regs[r] + inst.value; }
            .sub => {
                if (inst.value <= regs[r]) {
                    regs[r] = regs[r] - inst.value;
                } else {
                    regs[r] = 0;
                }
            }
            .mul => { regs[r] = regs[r] * inst.value; }
            .print => { output = output + regs[r]; }
            .halt => { return output; }
        }
    }
    return output;
}

u32 main() {
    Instruction[16] prog;
    // r0 = 10
    prog[0].op = OpCode.set; prog[0].reg = 0; prog[0].value = 10;
    // r1 = 5
    prog[1].op = OpCode.set; prog[1].reg = 1; prog[1].value = 5;
    // r0 += 20 -> 30
    prog[2].op = OpCode.add; prog[2].reg = 0; prog[2].value = 20;
    // r0 *= 2 -> 60
    prog[3].op = OpCode.mul; prog[3].reg = 0; prog[3].value = 2;
    // r1 -= 3 -> 2
    prog[4].op = OpCode.sub; prog[4].reg = 1; prog[4].value = 3;
    // output += r0 -> 60
    prog[5].op = OpCode.print; prog[5].reg = 0; prog[5].value = 0;
    // output += r1 -> 62
    prog[6].op = OpCode.print; prog[6].reg = 1; prog[6].value = 0;
    // halt
    prog[7].op = OpCode.halt; prog[7].reg = 0; prog[7].value = 0;

    u32 result = execute(prog, 8);
    if (result != 62) { return 1; }
    return 0;
}
