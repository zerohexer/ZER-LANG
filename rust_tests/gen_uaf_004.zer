// UAF: cross-function free, then use in caller
// EXPECTED: compile error

struct Rec { u32 data; }
Pool(Rec, 4) pool;

void destroy(Handle(Rec) h) {
    pool.free(h);
}

u32 main() {
    ?Handle(Rec) mh = pool.alloc();
    Handle(Rec) h = mh orelse return;
    pool.get(h).data = 7;
    destroy(h);
    u32 v = pool.get(h).data;
    return v;
}
