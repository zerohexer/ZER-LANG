// Rust: 4 threads running in parallel, each writes own slot.
// ZER: 4 scoped spawns with shared struct, write independent fields.

shared struct Slots { u32 s0; u32 s1; u32 s2; u32 s3; }
Slots g_slots;

void fill_0(*Slots s) { s.s0 = 10; }
void fill_1(*Slots s) { s.s1 = 20; }
void fill_2(*Slots s) { s.s2 = 30; }
void fill_3(*Slots s) { s.s3 = 40; }

i32 main() {
    g_slots.s0 = 0;
    g_slots.s1 = 0;
    g_slots.s2 = 0;
    g_slots.s3 = 0;

    ThreadHandle t0 = spawn fill_0(&g_slots);
    ThreadHandle t1 = spawn fill_1(&g_slots);
    ThreadHandle t2 = spawn fill_2(&g_slots);
    ThreadHandle t3 = spawn fill_3(&g_slots);

    t0.join();
    t1.join();
    t2.join();
    t3.join();

    u32 sum = g_slots.s0 + g_slots.s1 + g_slots.s2 + g_slots.s3;
    if (sum != 100) { return 1; }
    return 0;
}
