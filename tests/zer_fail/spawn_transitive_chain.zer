// AUDIT2 #4 (2026-04-19 code-inspection audit)
// CLAIM: checker.c:6466 `_scan_depth < 8` — transitive data-race
//        detection on spawn follows call chains only 8 levels deep.
//        If a spawned function calls through a chain of 9+ helpers
//        before touching a non-shared global, the unsafe access
//        is NOT detected.
// TEST: spawn entry → f1 → f2 → ... → f10 → touch `g`
// EXPECTED: if gap exists, compile accepts; data race at runtime.

u32 g;

void f10() { g = g + 1; }
void f9()  { f10(); }
void f8()  { f9(); }
void f7()  { f8(); }
void f6()  { f7(); }
void f5()  { f6(); }
void f4()  { f5(); }
void f3()  { f4(); }
void f2()  { f3(); }
void f1()  { f2(); }
void entry() { f1(); }

u32 main() {
    spawn entry();
    return 0;
}
