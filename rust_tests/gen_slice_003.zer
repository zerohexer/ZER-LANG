// Slice: OOB access on slice at runtime — auto-guard

u32 global_val;

void set_via_slice([*]u32 s, u32 idx, u32 val) {
    // auto-guard inserted for unproven idx
    s[idx] = val;
}

u32 main() {
    u32[4] arr;
    arr[0] = 0;
    arr[1] = 0;
    arr[2] = 0;
    arr[3] = 0;

    set_via_slice(arr, 2, 42);
    if (arr[2] != 42) { return 1; }
    return 0;
}
