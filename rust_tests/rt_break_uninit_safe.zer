// Rust source: tests/ui/borrowck/borrowck-break-uninit.rs
// Safety intent: variable assigned after break is unreachable — uninit use.
// ZER: auto-zero prevents uninitialized memory. Variable is 0 after break.

u32 foo() {
    u32 x = 0;  // ZER auto-zeros, so x starts at 0

    u32 i = 0;
    while (i < 10) {
        if (i == 0) {
            break;
        }
        x = 42;  // never reached
        i += 1;
    }

    // In Rust this is E0381 (uninit). In ZER, x is auto-zeroed = 0.
    return x;
}

u32 main() {
    u32 result = foo();
    if (result != 0) { return 1; }
    return 0;
}
