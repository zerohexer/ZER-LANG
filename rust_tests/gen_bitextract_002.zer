// Bit extraction: combine extracted fields

u32 main() {
    u32 reg = 0xA5B3C7D9;

    u32 byte0 = reg[7..0];
    u32 byte1 = reg[15..8];
    u32 byte2 = reg[23..16];
    u32 byte3 = reg[31..24];

    if (byte0 != 0xD9) { return 1; }
    if (byte1 != 0xC7) { return 2; }
    if (byte2 != 0xB3) { return 3; }
    if (byte3 != 0xA5) { return 4; }
    return 0;
}
