// Rust pattern: callback with *opaque context — full lifecycle.
// ZER: register callback, invoke it, cleanup properly.
// NOTE: context is global — a funcptr callback is worst-case `keep`, so a
// stack-local context is rejected (see docs/limitations.md).

struct Timer { u32 interval; u32 count; }

void timer_tick(*opaque ctx) {
    *Timer t = @ptrcast(*Timer, ctx);
    t.count += 1;
}

struct Callback {
    *opaque ctx;
    void (*handler)(*opaque);
}

Timer g_timer;

u32 main() {
    g_timer.interval = 100;
    g_timer.count = 0;

    Callback cb;
    cb.ctx = @ptrcast(*opaque, &g_timer);
    cb.handler = timer_tick;

    // Simulate 5 ticks
    cb.handler(cb.ctx);
    cb.handler(cb.ctx);
    cb.handler(cb.ctx);
    cb.handler(cb.ctx);
    cb.handler(cb.ctx);

    if (g_timer.count != 5) { return 1; }
    if (g_timer.interval != 100) { return 2; }

    return 0;
}
