// AUDIT 2026-06-17 — MEDIUM severity (silent use-after-move via
// variable-index array element)
//
// Gap: `ir_extract_compound_key` rejects variable indices (returns
// -1 when index isn't NODE_INT_LIT). The IR_COPY move-transfer
// handler uses this to find the source handle; when the source is
// `arr[i]` (variable i), the extraction fails, the move silently
// goes untracked, and the analyzer keeps every element of `arr`
// in ALIVE state.
//
// Companion to BUG-741 (variable-index FREE of array element = error
// via the argument-precise barrier principle). The widening was
// applied to FREE only, not to MOVE.
//
// Real safety issue: subsequent literal-index reads/writes of any
// element of the same array can hit the element that was actually
// moved (any j when i was variable). Use-after-move on move-struct
// is silent UB.
//
// Expected: COMPILE ERROR (e.g. "variable-index move from array —
//           any element may have been moved; index by literal or
//           hand off whole array")
// Actual:   compiles clean.

move struct Token { u32 kind; }
void consume(Token t) { t.kind = t.kind; }

u32 main() {
    Token[4] arr;
    arr[0].kind = 42;
    arr[1].kind = 99;
    u32 i = 1;
    Token m = arr[i];      // variable-index MOVE — silently untracked
    consume(m);
    u32 v = arr[0].kind;   // arr[0] may have been the moved element
    return v;
}
