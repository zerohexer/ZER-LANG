// EXPECTED: compile error
// CFG test: backward goto with free — fixed-point detects UAF on re-entry.

struct Item { u32 id; }
Pool(Item, 4) pool;

i32 main() {
    ?Handle(Item) mh = pool.alloc();
    Handle(Item) h = mh orelse return;
    pool.get(h).val = 1;

    u32 count = 0;
retry:
    u32 v = pool.get(h).id;   // UAF after goto re-enters with h freed
    pool.free(h);
    count += 1;
    if (count < 3) {
        goto retry;            // backward jump — h freed, retry uses it
    }
    return 0;
}
