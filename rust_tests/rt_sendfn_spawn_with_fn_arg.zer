// Rust source: tests/ui/threads-sendsync/sendfn-spawn-with-fn-arg.rs
// Spawn with function pointer argument — pass a function as argument to spawned thread.
// BUG-465 fixed: spawn wrapper struct now uses emit_type_and_name for funcptr fields.

shared struct Result { u32 value; }
Result res;

u32 double_it(u32 x) {
    return x * 2;
}

u32 add_ten(u32 x) {
    return x + 10;
}

void worker(*Result r, u32 (*op)(u32), u32 arg) {
    r.value = op(arg);
}

u32 main() {
    res.value = 0;

    // Spawn with funcptr arg — double_it(21) = 42
    ThreadHandle th = spawn worker(&res, double_it, 21);
    th.join();
    if (res.value != 42) { return 1; }

    // Spawn with different funcptr — add_ten(32) = 42
    ThreadHandle th2 = spawn worker(&res, add_ten, 32);
    th2.join();
    if (res.value != 42) { return 2; }

    return 0;
}
