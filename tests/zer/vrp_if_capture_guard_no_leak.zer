// A bounds guard inside an if-capture body must NOT leak past the capture join
// (VRP scope leak, BH-18 #2 sibling, 2026-07-09). maybe() is null so the body
// never runs; with the fix buf[idx] is auto-guarded (idx=9 OOB) -> return 0.
u32 g = 9;
?u32 maybe() { return null; }
u32 main() {
    u8[4] buf;
    buf[0] = 0;
    u32 idx = g;
    if (maybe()) |v| { if (idx >= 4) { return 0; } }
    buf[idx] = 7;
    return 1;
}
