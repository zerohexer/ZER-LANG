// Ring buffer: fill to capacity and verify wraparound

Ring(u8, 4) ring;

u32 main() {
    ring.push(1);
    ring.push(2);
    ring.push(3);
    ring.push(4);

    ?u8 v1 = ring.pop();
    u8 a = v1 orelse return;
    if (a != 1) { return 1; }

    ring.push(5);

    ?u8 v2 = ring.pop();
    u8 b = v2 orelse return;
    if (b != 2) { return 2; }

    ?u8 v3 = ring.pop();
    u8 c = v3 orelse return;
    if (c != 3) { return 3; }
    return 0;
}
