// Scoped-borrow read-side positive: reading the local AFTER .join() is safe — the
// thread is finished and the borrow is cleared, so there is no race. Proves the
// read-side ban is windowed (spawn..join), not blanket.
struct Work { u32 result; }
void compute(*Work w) { w.result = 42; }
u32 main() {
    Work job;
    job.result = 0;
    ThreadHandle th = spawn compute(&job);
    th.join();
    u32 x = job.result;     // read AFTER join — OK
    if (x != 42) { return 1; }
    return 0;
}
