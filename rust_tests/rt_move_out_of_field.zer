// Rust source: tests/ui/moves/move-out-of-field.rs
// Safety intent: moving field out of struct consumes the struct.
// ZER: ownership transfer via alloc_ptr + handle tracking.

struct Buffer { u32 len; u32 cap; }
Slab(Buffer) buffers;

u32 extract_len(*Buffer b) {
    u32 result = b.len;
    return result;
}

u32 main() {
    ?*Buffer mb = buffers.alloc_ptr();
    *Buffer buf = mb orelse return;
    defer buffers.free_ptr(buf);

    buf.len = 42;
    buf.cap = 100;

    // Extract field value — safe, scalar copy
    u32 len = extract_len(buf);
    if (len != 42) { return 1; }

    // Original still valid (ZER doesn't move scalars)
    if (buf.cap != 100) { return 2; }

    return 0;
}
