// A6-full slice 2 regression guard (positive): an atomic READ (@atomic_load) of
// an atomic cell after a fire-and-forget spawn is the correct synchronized
// access — compiles fine. Also a plain read AFTER a scoped spawn's join is safe
// (the thread is done), which the fire-and-forget gate leaves legal.
u32 g;
void worker() { @atomic_add(&g, 1); }
u32 main() {
    @atomic_store(&g, 0);
    ThreadHandle th = spawn worker();
    th.join();
    u32 x = g;
    if (x != 1) { return 1; }
    return 0;
}
