// Rust: Arc<Mutex<T>> — fire-and-forget spawn with value args (copy semantics)
// ZER: spawn with value arguments — copied, no sharing needed
// Equivalent to: Rust thread::spawn with captured values (Copy types)

shared struct Accumulator {
    u32 total;
}

Accumulator gacc;

void add_value(*Accumulator a, u32 x, u32 y) {
    a.total += x + y;
}

u32 main() {
    gacc.total = 0;

    // Value args x, y are copied into each thread — no sharing issue
    ThreadHandle t1 = spawn add_value(&gacc, 1, 2);
    ThreadHandle t2 = spawn add_value(&gacc, 3, 4);
    ThreadHandle t3 = spawn add_value(&gacc, 5, 6);

    t1.join();
    t2.join();
    t3.join();

    // (1+2) + (3+4) + (5+6) = 3 + 7 + 11 = 21
    u32 total = gacc.total;
    if (total != 21) { return 1; }
    return 0;
}
