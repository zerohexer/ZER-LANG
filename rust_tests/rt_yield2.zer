// Rust source: tests/ui/threads-sendsync/yield2.rs
// Safety scenario: parent yields (gives up its timeslice) to let child finish.
// Rust: thread::yield_now() in parent loop until child completes.
// ZER: ThreadHandle + join is the correct equivalent. Join blocks until thread done —
// semantically equivalent to "yield until child completes" but without busy-wait.
// Safety property: join() guarantees all child effects visible after return.

shared struct Work {
    u32 result;
}

Work gwork;

void child(*Work w) {
    w.result = 77;
}

u32 main() {
    gwork.result = 0;

    ThreadHandle th = spawn child(&gwork);

    // "Parent yields to let child run" — in ZER, join() is the correct primitive
    th.join();

    u32 v = gwork.result;
    if (v != 77) { return 1; }
    return 0;
}
