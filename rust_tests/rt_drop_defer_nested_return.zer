// Rust drop: nested resources — inner Drop fires before outer.
// ZER: two resources, inner freed by defer on early return, outer by outer defer.

struct Outer { u32 id; }
struct Inner { u32 id; }
Pool(Outer, 4) outer_pool;
Pool(Inner, 4) inner_pool;

u32 nested_work(u32 fail_at) {
    ?Handle(Outer) mo = outer_pool.alloc();
    Handle(Outer) ho = mo orelse return;
    defer outer_pool.free(ho);
    outer_pool.get(ho).id = 1;

    ?Handle(Inner) mi = inner_pool.alloc();
    Handle(Inner) hi = mi orelse return;
    defer inner_pool.free(hi);
    inner_pool.get(hi).id = 2;

    if (fail_at == 1) { return 10; }   // both defers fire
    if (fail_at == 2) { return 20; }

    return ho.id + hi.id;
}

i32 main() {
    u32 r0 = nested_work(0);
    u32 r1 = nested_work(1);
    u32 r2 = nested_work(2);
    if (r0 != 3) { return 1; }
    if (r1 != 10) { return 2; }
    if (r2 != 20) { return 3; }
    return 0;
}
