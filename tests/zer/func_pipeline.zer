// Hard test 6: Data processing pipeline with function pointers
// Exercises: typedef ?T (*Fn)(T), array of funcptr typedefs, chained calls,
//            orelse with continue in for loop, struct return from pipeline

typedef ?u32 (*Transform)(u32 input);

?u32 double_val(u32 x) { return x * 2; }
?u32 add_ten(u32 x) { return x + 10; }
?u32 reject_odd(u32 x) {
    if (x % 2 != 0) { return null; }
    return x;
}
?u32 cap_at_100(u32 x) {
    if (x > 100) { return null; }
    return x;
}

struct PipeResult {
    u32 output;
    bool ok;
    u32 failed_stage;
}

PipeResult run_pipeline(u32 input, Transform[4] stages, u32 stage_count) {
    PipeResult result;
    result.output = input;
    result.ok = true;
    result.failed_stage = 0;

    u32 val = input;
    for (u32 i = 0; i < stage_count; i += 1) {
        if (i >= 4) { break; }
        ?u32 next = stages[i](val);
        if (next) |n| {
            val = n;
        } else {
            result.ok = false;
            result.failed_stage = i;
            result.output = val;
            return result;
        }
    }
    result.output = val;
    return result;
}

// Reduce: apply binary op across array
u32 reduce(u32[8] data, u32 count, u32 init) {
    u32 acc = init;
    for (u32 i = 0; i < count; i += 1) {
        if (i >= 8) { break; }
        acc = acc + data[i];
    }
    return acc;
}

// Map: apply transform to each element, collecting results
u32 map_count(u32[8] data, u32 count, Transform fn) {
    u32 passed = 0;
    for (u32 i = 0; i < count; i += 1) {
        if (i >= 8) { break; }
        ?u32 result = fn(data[i]);
        if (result) |v| {
            passed = passed + 1;
        }
    }
    return passed;
}

u32 main() {
    // Pipeline: double → add_ten → reject_odd → cap_at_100
    Transform[4] pipeline;
    pipeline[0] = double_val;
    pipeline[1] = add_ten;
    pipeline[2] = reject_odd;
    pipeline[3] = cap_at_100;

    // Input 5: 5→10→20→20(even,ok)→20(<=100,ok) = 20
    PipeResult r1 = run_pipeline(5, pipeline, 4);
    if (!r1.ok) { return 1; }
    if (r1.output != 20) { return 2; }

    // Input 10: 10→20→30→30(even,ok)→30(<=100,ok) = 30
    PipeResult r2 = run_pipeline(10, pipeline, 4);
    if (!r2.ok) { return 3; }
    if (r2.output != 30) { return 4; }

    // Input 3: 3→6→16→16(even,ok)→16(<=100,ok) = 16
    PipeResult r3 = run_pipeline(3, pipeline, 4);
    if (!r3.ok) { return 5; }
    if (r3.output != 16) { return 6; }

    // Input 2: 2→4→14→14(even,ok)→14(<=100,ok) = 14
    PipeResult r4 = run_pipeline(2, pipeline, 4);
    if (!r4.ok) { return 7; }
    if (r4.output != 14) { return 8; }

    // Input 50: 50→100→110→110(even,ok)→FAIL(>100) at stage 3
    PipeResult r5 = run_pipeline(50, pipeline, 4);
    if (r5.ok) { return 9; }
    if (r5.failed_stage != 3) { return 10; }

    // Reduce test
    u32[8] data;
    data[0] = 1; data[1] = 2; data[2] = 3; data[3] = 4;
    data[4] = 5; data[5] = 6; data[6] = 7; data[7] = 8;
    u32 sum = reduce(data, 8, 0);
    if (sum != 36) { return 11; }

    // Map test: count even numbers
    u32 even_count = map_count(data, 8, reject_odd);
    if (even_count != 4) { return 12; }  // 2,4,6,8

    return 0;
}
