// Goto: forward jump to cleanup label

struct Res { u32 id; }
Pool(Res, 4) pool;

u32 run(bool fail) {
    ?Handle(Res) mh = pool.alloc();
    Handle(Res) h = mh orelse return;
    pool.get(h).id = 7;

    if (fail) {
        goto cleanup;
    }

    pool.get(h).id = 99;

cleanup:
    pool.free(h);
    return 0;
}

u32 main() {
    u32 r1 = run(false);
    if (r1 != 0) { return 1; }
    u32 r2 = run(true);
    if (r2 != 0) { return 2; }
    return 0;
}
