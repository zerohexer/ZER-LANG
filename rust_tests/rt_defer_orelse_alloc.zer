// Rust pattern: Result-based allocation with cleanup on all paths.
// ZER: alloc orelse return, defer free, use in between. POSITIVE.

struct Request {
    u32 id;
    u32 payload_len;
    u32 status;
}

Pool(Request, 8) pool;

u32 process_request(Handle(Request) h) {
    return h.id + h.payload_len;
}

i32 main() {
    ?Handle(Request) mh = pool.alloc();
    Handle(Request) h = mh orelse return;
    defer pool.free(h);

    h.id = 42;
    h.payload_len = 256;
    h.status = 0;

    u32 result = process_request(h);
    if (result != 298) {
        return 1;
    }

    h.status = 1;
    return 0;
}
