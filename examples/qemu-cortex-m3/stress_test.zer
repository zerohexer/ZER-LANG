// ZER Stress Test — Every Untested Feature Combination
// =====================================================
// Exercises: tagged union + capture, Arena + defer reset loop,
// packed struct + bit extraction + volatile, nested if-unwrap,
// array→slice coercion, distinct typedef, defer + orelse return,
// multi-level struct field access, ?*Struct with ?field.

volatile *u32 UART0_DR = @inttoptr(*u32, 0x4000C000);
volatile *u32 UART0_FR = @inttoptr(*u32, 0x4000C018);

void uart_putc(u8 c) {
    while ((*UART0_FR & 0x20) != 0) { }
    *UART0_DR = @truncate(u32, c);
}

void uart_puts([]u8 s) {
    for (usize i = 0; i < s.len; i += 1) {
        uart_putc(s[i]);
    }
}

void uart_put_u32(u32 val) {
    u8[10] buf;
    u32 pos = 0;
    if (val == 0) { uart_putc(48); return; }
    u32 tmp = val;
    while (tmp > 0) {
        buf[pos] = @truncate(u8, (tmp % 10) + 48);
        pos += 1;
        tmp = tmp / 10;
    }
    while (pos > 0) { pos -= 1; uart_putc(buf[pos]); }
}

void nl() { uart_putc(13); uart_putc(10); }

void pass([]u8 name) { uart_puts("  PASS: "); uart_puts(name); nl(); }
void fail([]u8 name) { uart_puts("  FAIL: "); uart_puts(name); nl(); }

u32 test_count = 0;
u32 pass_count = 0;

void check(bool cond, []u8 name) {
    test_count += 1;
    if (cond) { pass_count += 1; pass(name); }
    else { fail(name); }
}

// ============================================================
// TEST 1: Tagged Union with captures (immutable + mutable)
// ============================================================

struct SensorData { u32 temp; u32 humidity; }
struct Command { u32 code; u32 arg; }
struct Ack { u32 seq; }
union Message { SensorData sensor; Command command; Ack ack; }

u32 test_tagged_union() {
    // Immutable capture
    Message msg;
    SensorData sd;
    sd.temp = 25;
    sd.humidity = 60;
    msg.sensor = sd;

    u32 result = 0;
    switch (msg) {
        .sensor => |data| {
            result = data.temp + data.humidity;
        }
        .command => |cmd| {
            result = cmd.code;
        }
        .ack => |a| {
            result = a.seq;
        }
    }
    check(result == 85, "tagged union immutable capture: 25+60=85");

    // Mutable capture
    Message msg2;
    Command c;
    c.code = 10;
    c.arg = 20;
    msg2.command = c;

    switch (msg2) {
        .sensor => |data| { }
        .command => |*cmd| {
            cmd.code = 99;
        }
        .ack => |a| { }
    }

    u32 modified = 0;
    switch (msg2) {
        .sensor => |data| { modified = 0; }
        .command => |cmd| { modified = cmd.code; }
        .ack => |a| { modified = 0; }
    }
    check(modified == 99, "tagged union mutable capture: code changed to 99");

    return result + modified;
}

// ============================================================
// TEST 2: Arena alloc + defer reset in loop (scratch pattern)
// ============================================================

u8[4096] scratch_mem;
Arena scratch;

struct TempResult { u32 sum; u32 count; }

u32 test_arena_defer_loop() {
    scratch = Arena.over(scratch_mem);
    u32 total = 0;

    for (u32 iter = 1; iter <= 4; iter += 1) {
        defer scratch.unsafe_reset();

        *TempResult r = scratch.alloc(TempResult) orelse return;
        r.sum = iter * 10;
        r.count = iter;
        total += r.sum;
    }
    // After 4 iterations: 10 + 20 + 30 + 40 = 100
    check(total == 100, "arena + defer reset loop: 10+20+30+40=100");
    return total;
}

// ============================================================
// TEST 3: Packed struct + bit extraction + volatile
// ============================================================

packed struct HardwareReg {
    u8 status;
    u8 control;
    u16 data;
}

u32 test_packed_bits() {
    HardwareReg reg;
    reg.status = 0xA5;
    reg.control = 0x3C;
    reg.data = 0xBEEF;

    // Bit extraction on fields
    u32 status_val = @truncate(u32, reg.status);
    u32 low_nibble = status_val[3..0];   // 0x5
    u32 high_nibble = status_val[7..4];  // 0xA = 10

    check(low_nibble == 5, "packed struct bit extract low nibble: 5");
    check(high_nibble == 10, "packed struct bit extract high nibble: 0xA=10");

    // Volatile register simulation
    volatile *u32 fake_reg = @inttoptr(*u32, 0x40001000);
    // Can't deref on QEMU (unmapped), but the declaration compiles
    // This proves volatile + @inttoptr + packed struct all work together

    return low_nibble + high_nibble;
}

// ============================================================
// TEST 4: Nested if-unwrap (?*Struct with ?field)
// ============================================================

struct Config {
    u32 base_addr;
    ?u32 timeout;
    ?u32 retry_count;
}

Config g_config;

?*Config get_config(bool valid) {
    if (!valid) { return null; }
    g_config.base_addr = 0x4000;
    g_config.timeout = 500;
    g_config.retry_count = null;
    return &g_config;
}

u32 test_nested_unwrap() {
    // Outer: ?*Config → unwrap to *Config
    // Inner: config.timeout is ?u32 → unwrap to u32
    *Config cfg = get_config(true) orelse return;

    u32 timeout = cfg.timeout orelse 100;
    u32 retries = cfg.retry_count orelse 3;

    check(timeout == 500, "nested unwrap: timeout present = 500");
    check(retries == 3, "nested unwrap: retry_count null, default = 3");

    // Test null outer
    ?*Config no_cfg = get_config(false);
    u32 fallback = 0;
    if (no_cfg) |c| {
        fallback = c.base_addr;
    } else {
        fallback = 999;
    }
    check(fallback == 999, "nested unwrap: null outer → else branch = 999");

    return timeout + retries + fallback;
}

// ============================================================
// TEST 5: Array→slice coercion at call site
// ============================================================

u32 sum_bytes([]u8 data) {
    u32 total = 0;
    for (usize i = 0; i < data.len; i += 1) {
        total += @truncate(u32, data[i]);
    }
    return total;
}

u32 test_array_to_slice() {
    u8[5] arr;
    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    arr[3] = 40;
    arr[4] = 50;

    // Array passed to function expecting slice — coercion at call site
    u32 result = sum_bytes(arr);
    check(result == 150, "array→slice coercion at call: 10+20+30+40+50=150");

    // Also test with var-decl coercion
    []u8 sl = arr;
    u32 result2 = sum_bytes(sl);
    check(result2 == 150, "array→slice at var-decl then pass: 150");

    return result;
}

// ============================================================
// TEST 6: Distinct typedef in real usage
// ============================================================

distinct typedef u32 Celsius;
distinct typedef u32 Fahrenheit;

Fahrenheit celsius_to_f(Celsius c) {
    u32 raw = @truncate(u32, c);
    u32 f = raw * 9 / 5 + 32;
    return @cast(Fahrenheit, f);
}

u32 test_distinct_typedef() {
    Celsius boiling = @cast(Celsius, 100);
    Fahrenheit f = celsius_to_f(boiling);
    u32 raw_f = @truncate(u32, f);

    check(raw_f == 212, "distinct typedef: 100C → 212F");

    return raw_f;
}

// ============================================================
// TEST 7: defer + orelse return (defers MUST fire)
// ============================================================

u32 defer_fired = 0;

void mark_fired() { defer_fired = 1; }

?u32 always_null() { return null; }

void test_defer_orelse_inner() {
    defer mark_fired();
    u32 val = always_null() orelse return;
    // Should never reach here
    defer_fired = 99;
}

u32 test_defer_orelse() {
    defer_fired = 0;
    test_defer_orelse_inner();
    check(defer_fired == 1, "defer fires on orelse return: defer_fired=1");
    return defer_fired;
}

// ============================================================
// TEST 8: Multi-level struct field access through pointer
// ============================================================

struct Inner { u32 value; }
struct Middle { Inner inner; u32 tag; }
struct Outer { Middle mid; u32 id; }

Outer g_outer;

u32 test_deep_field_access() {
    g_outer.id = 1;
    g_outer.mid.tag = 42;
    g_outer.mid.inner.value = 100;

    *Outer p = &g_outer;

    // 3-level deep access through pointer
    u32 deep_val = p.mid.inner.value;
    check(deep_val == 100, "3-level field access through ptr: 100");

    // Modify through pointer
    p.mid.inner.value = 200;
    check(g_outer.mid.inner.value == 200, "3-level modify through ptr: 200");

    return deep_val;
}

// ============================================================
// TEST 9: ?FuncPtr as callback table entry
// ============================================================

typedef void (*Handler)(u32);

struct CmdEntry {
    u32 code;
    ?Handler handler;
}

u32 handler_result = 0;

void handle_read(u32 addr) { handler_result = addr + 1; }
void handle_write(u32 addr) { handler_result = addr + 2; }

u32 test_callback_table() {
    CmdEntry[3] table;
    table[0].code = 1;
    table[0].handler = handle_read;
    table[1].code = 2;
    table[1].handler = handle_write;
    table[2].code = 3;
    table[2].handler = null;  // unregistered

    // Dispatch command 1
    handler_result = 0;
    if (table[0].handler) |h| { h(10); }
    check(handler_result == 11, "callback table: handle_read(10) = 11");

    // Dispatch command 2
    handler_result = 0;
    if (table[1].handler) |h| { h(20); }
    check(handler_result == 22, "callback table: handle_write(20) = 22");

    // Dispatch command 3 (null handler)
    handler_result = 0;
    if (table[2].handler) |h| { h(30); }
    check(handler_result == 0, "callback table: null handler not called");

    return handler_result;
}

// ============================================================
// TEST 10: Everything combined — Arena + tagged union + defer
// ============================================================

u8[2048] combined_mem;
Arena combined_arena;

struct LogEntry { u32 timestamp; Message msg; }

u32 test_combined() {
    combined_arena = Arena.over(combined_mem);

    u32 total_processed = 0;

    for (u32 tick = 0; tick < 3; tick += 1) {
        defer combined_arena.unsafe_reset();

        *LogEntry entry = combined_arena.alloc(LogEntry) orelse return;
        entry.timestamp = tick * 100;

        // Alternate message types per tick
        if (tick == 0) {
            SensorData sd;
            sd.temp = 25;
            sd.humidity = 50;
            entry.msg.sensor = sd;
        } else {
            if (tick == 1) {
                Command c;
                c.code = 42;
                c.arg = 7;
                entry.msg.command = c;
            } else {
                Ack a;
                a.seq = 99;
                entry.msg.ack = a;
            }
        }

        // Process based on message type
        switch (entry.msg) {
            .sensor => |data| {
                total_processed += data.temp;
            }
            .command => |cmd| {
                total_processed += cmd.code;
            }
            .ack => |a| {
                total_processed += a.seq;
            }
        }
    }

    // 25 + 42 + 99 = 166
    check(total_processed == 166, "combined arena+union+defer: 25+42+99=166");
    return total_processed;
}

// ============================================================
// MAIN
// ============================================================

void main() {
    uart_puts("========================================");
    nl();
    uart_puts("  ZER Stress Test — Cortex-M3 (QEMU)");
    nl();
    uart_puts("  Every untested feature combination");
    nl();
    uart_puts("========================================");
    nl();

    test_tagged_union();
    test_arena_defer_loop();
    test_packed_bits();
    test_nested_unwrap();
    test_array_to_slice();
    test_distinct_typedef();
    test_defer_orelse();
    test_deep_field_access();
    test_callback_table();
    test_combined();

    nl();
    uart_puts("Results: ");
    uart_put_u32(pass_count);
    uart_putc(47);  // '/'
    uart_put_u32(test_count);
    uart_puts(" passed");
    nl();

    if (pass_count == test_count) {
        uart_puts("ALL TESTS PASSED. ZER is solid.");
    } else {
        uart_puts("SOME TESTS FAILED.");
    }
    nl();

    while (true) { }
}
