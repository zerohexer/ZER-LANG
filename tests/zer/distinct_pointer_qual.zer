// Distinct typedef wrapping pointer — const/volatile qualifiers

distinct typedef *u32 IntRef;

u32 g_val = 42;

u32 read_ref(IntRef r) {
    *u32 raw = @cast(*u32, r);
    return raw[0];
}

u32 main() {
    IntRef r = @cast(IntRef, &g_val);
    u32 v = read_ref(r);
    if (v != 42) { return 1; }
    return 0;
}
