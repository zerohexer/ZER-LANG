// Interior pointer used BEFORE free — must compile and run
// &b.field is valid while b is alive

struct Block { u32 a; u32 b; u32 c; }
Slab(Block) heap;

u32 main() {
    ?*Block mb = heap.alloc_ptr();
    *Block b = mb orelse return;
    b.a = 10;
    b.b = 20;
    b.c = 30;

    // Take field pointers while alive — safe
    *u32 pa = &b.a;
    *u32 pb = &b.b;

    // Read through interior pointers before free
    u32 sum = pa[0] + pb[0];

    // Free after use
    heap.free_ptr(b);

    if (sum != 30) { return 1; }
    return 0;
}
