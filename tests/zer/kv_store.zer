// Real program 4: Key-value store with open-addressing hash map
// Exercises: comptime, arrays, struct fields, for loops, modulo range proof,
//            optional return, orelse, nested if-else, bit operations

comptime u32 MAP_SIZE() { return 16; }
comptime u32 MAP_MASK() { return MAP_SIZE() - 1; }
comptime u32 EMPTY_KEY() { return 0xFFFFFFFF; }

struct Entry {
    u32 key;
    u32 value;
}

struct HashMap {
    Entry[MAP_SIZE()] entries;
    u32 count;
}

void map_init(*HashMap m) {
    m.count = 0;
    for (u32 i = 0; i < MAP_SIZE(); i += 1) {
        m.entries[i].key = EMPTY_KEY();
        m.entries[i].value = 0;
    }
}

u32 hash_key(u32 key) {
    u32 h = key;
    h = h ^ (h >> 16);
    h = h * 0x45D9F3B;
    h = h ^ (h >> 16);
    return h & MAP_MASK();
}

// Insert key-value pair. Returns false if map is full.
bool map_put(*HashMap m, u32 key, u32 value) {
    if (m.count >= MAP_SIZE()) { return false; }

    u32 slot = hash_key(key);
    for (u32 i = 0; i < MAP_SIZE(); i += 1) {
        u32 idx = (slot + i) & MAP_MASK();
        u32 existing = m.entries[idx].key;
        if (existing == EMPTY_KEY()) {
            m.entries[idx].key = key;
            m.entries[idx].value = value;
            m.count = m.count + 1;
            return true;
        }
        if (existing == key) {
            // Update existing
            m.entries[idx].value = value;
            return true;
        }
    }
    return false;
}

// Lookup a key. Returns null if not found.
?u32 map_get(*HashMap m, u32 key) {
    u32 slot = hash_key(key);
    for (u32 i = 0; i < MAP_SIZE(); i += 1) {
        u32 idx = (slot + i) & MAP_MASK();
        u32 k = m.entries[idx].key;
        if (k == EMPTY_KEY()) { return null; }
        if (k == key) {
            return m.entries[idx].value;
        }
    }
    return null;
}

// Delete a key. Returns true if found and removed.
bool map_delete(*HashMap m, u32 key) {
    u32 slot = hash_key(key);
    for (u32 i = 0; i < MAP_SIZE(); i += 1) {
        u32 idx = (slot + i) & MAP_MASK();
        u32 k = m.entries[idx].key;
        if (k == EMPTY_KEY()) { return false; }
        if (k == key) {
            m.entries[idx].key = EMPTY_KEY();
            m.entries[idx].value = 0;
            m.count = m.count - 1;
            return true;
        }
    }
    return false;
}

u32 main() {
    HashMap map;
    map_init(&map);

    // Insert entries
    if (!map_put(&map, 1, 100)) { return 1; }
    if (!map_put(&map, 2, 200)) { return 2; }
    if (!map_put(&map, 3, 300)) { return 3; }
    if (!map_put(&map, 17, 1700)) { return 4; }  // might collide with key 1

    if (map.count != 4) { return 5; }

    // Lookup
    u32 v1 = map_get(&map, 1) orelse { return 6; };
    if (v1 != 100) { return 7; }

    u32 v2 = map_get(&map, 2) orelse { return 8; };
    if (v2 != 200) { return 9; }

    u32 v3 = map_get(&map, 3) orelse { return 10; };
    if (v3 != 300) { return 11; }

    u32 v17 = map_get(&map, 17) orelse { return 12; };
    if (v17 != 1700) { return 13; }

    // Lookup missing key
    ?u32 missing = map_get(&map, 999);
    if (missing) |v| { return 14; }

    // Update existing key
    if (!map_put(&map, 2, 222)) { return 15; }
    u32 updated = map_get(&map, 2) orelse { return 16; };
    if (updated != 222) { return 17; }
    if (map.count != 4) { return 18; }  // count should not change on update

    // Delete
    if (!map_delete(&map, 3)) { return 19; }
    if (map.count != 3) { return 20; }

    ?u32 deleted = map_get(&map, 3);
    if (deleted) |v| { return 21; }

    // Remaining entries still accessible
    u32 still1 = map_get(&map, 1) orelse { return 22; };
    if (still1 != 100) { return 23; }

    return 0;
}
