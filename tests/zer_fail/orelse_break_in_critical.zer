// EXPECTED: compile error
// `orelse break` from inside @critical inside a loop also skips
// interrupt re-enable (same hazard class as orelse_return_in_critical).

struct T { u32 id; }
Pool(T, 4) p;
?Handle(T) maybe;

void test() {
    for (u32 i = 0; i < 1; i += 1) {
        @critical {
            Handle(T) h = maybe orelse break;
            p.free(h);
        }
    }
}

void main() { test(); }
