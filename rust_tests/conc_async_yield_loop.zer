// Rust: async fn with loop + .await — state preserved across yields
// ZER: async + yield in while loop — locals promoted to state struct

u32 result;
u32 done;

async void fibonacci() {
    u32 a = 0;
    u32 b = 1;
    u32 count = 0;
    while (count < 10) {
        u32 next = a + b;
        a = b;
        b = next;
        count += 1;
        yield;
    }
    result = a;
    done = 1;
}

u32 main() {
    result = 0;
    done = 0;
    _zer_async_fibonacci task;
    _zer_async_fibonacci_init(&task);
    while (done == 0) {
        _zer_async_fibonacci_poll(&task);
    }
    // fib(10) = 55
    if (result != 55) { return 1; }
    return 0;
}
