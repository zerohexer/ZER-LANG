// Rust source: tests/ui/threads-sendsync/task-comm-17.rs
// Spawn temp closure that calls f(). Issue #922.
// ZER: ThreadHandle th = spawn f(); th.join(); — minimal scoped spawn.

shared struct Result { u32 called; }
Result res;

void f(*Result r) {
    r.called = 1;
}

u32 main() {
    res.called = 0;
    ThreadHandle th = spawn f(&res);
    th.join();
    if (res.called != 1) { return 1; }
    return 0;
}
