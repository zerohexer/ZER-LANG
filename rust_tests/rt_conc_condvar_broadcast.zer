// Condvar broadcast: wake all waiting threads

shared struct Gate { u32 open; }
Gate g;

void waiter() {
    @cond_wait(g, g.open == 1);
}

u32 main() {
    g.open = 0;
    ThreadHandle t1 = spawn waiter();
    ThreadHandle t2 = spawn waiter();
    ThreadHandle t3 = spawn waiter();
    g.open = 1;
    @cond_broadcast(g);
    t1.join();
    t2.join();
    t3.join();
    return 0;
}
