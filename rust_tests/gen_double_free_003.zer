// Double free: free through a function, then free again in caller
// EXPECTED: compile error

struct Packet { u32 len; }
Pool(Packet, 4) pool;

void release(Handle(Packet) h) {
    pool.free(h);
}

u32 main() {
    ?Handle(Packet) mh = pool.alloc();
    Handle(Packet) h = mh orelse return;
    pool.get(h).len = 64;
    release(h);
    pool.free(h);
    return 0;
}
