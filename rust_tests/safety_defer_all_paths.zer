// Rust: Drop runs on all exit paths (return, panic, scope exit)
// ZER: defer runs on all exit paths (return, break, continue, scope exit)

struct Counter { u32 count; }
Slab(Counter) heap;

u32 result;

u32 test_early_return(bool early) {
    ?*Counter mc = heap.alloc_ptr();
    *Counter c = mc orelse return;
    defer heap.free_ptr(c);

    c.count = 0;
    if (early) {
        c.count = 1;
        result = c.count;
        return 1;
    }
    c.count = 2;
    result = c.count;
    return 0;
}

u32 main() {
    result = 0;
    u32 r1 = test_early_return(true);
    if (r1 != 1) { return 1; }
    if (result != 1) { return 2; }

    u32 r2 = test_early_return(false);
    if (r2 != 0) { return 3; }
    if (result != 2) { return 4; }

    return 0;
}
