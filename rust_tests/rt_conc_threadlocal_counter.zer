// Translated from: rust/tests/ui/threads-sendsync/thread-local-syntax.rs
// Rust: thread_local! macro
// ZER: threadlocal keyword — each thread gets own copy

threadlocal u32 tl_count;

void count_up() {
    tl_count = 0;
    for (u32 i = 0; i < 100; i += 1) {
        tl_count += 1;
    }
}

i32 main() {
    tl_count = 0;
    ThreadHandle t1 = spawn count_up();
    ThreadHandle t2 = spawn count_up();
    t1.join();
    t2.join();
    // main thread's tl_count should be 0 (not modified by child threads)
    if (tl_count != 0) { return 1; }
    return 0;
}
