// Rust source: tests/ui/threads-sendsync/task-comm-4.rs
// Safety scenario: single-thread channel — same thread pushes 1..8, then
// pops all 8 and sums them. Verifies no deadlock in same-thread send/recv.
// sum = 1+2+3+4+5+6+7+8 = 36
// ZER: Ring(u32, 16). Push 1..8, pop all, assert sum == 36.

Ring(u32, 16) chan;

u32 main() {
    u32 i = 1;
    while (i <= 8) {
        chan.push(i);
        i += 1;
    }

    u32 sum = 0;
    u32 count = 0;
    while (count < 8) {
        ?u32 val = chan.pop();
        if (val) |v| {
            sum += v;
            count += 1;
        }
    }

    if (sum != 36) { return 1; }
    return 0;
}
