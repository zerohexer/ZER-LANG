// Rust pattern: AtomicBool CAS for spinlock.
// ZER: @atomic_cas for lock-free synchronization.

u32 lock;

void acquire() {
    while (!@atomic_cas(&lock, 0, 1)) {
        // spin
    }
}

void release() {
    @atomic_store(&lock, 0);
}

u32 main() {
    lock = 0;

    // Acquire lock
    acquire();
    if (@atomic_load(&lock) != 1) { return 1; }

    // Release lock
    release();
    if (@atomic_load(&lock) != 0) { return 2; }

    // Double acquire/release
    acquire();
    release();
    acquire();
    release();

    if (lock != 0) { return 3; }

    return 0;
}
