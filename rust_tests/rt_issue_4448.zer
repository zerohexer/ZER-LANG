// Rust source: tests/ui/threads-sendsync/issue-4448.rs
// Send string through channel; thread receives and asserts.
// ZER: shared struct with data field + ready flag. Thread reads after cond signal.

shared struct Msg {
    u32 data;
    u32 ready;
}

Msg g;

// "hello, world" encoded as length 12
void sender(*Msg m) {
    m.data = 12;
    m.ready = 1;
    @cond_signal(m);
}

u32 main() {
    g.data = 0;
    g.ready = 0;

    ThreadHandle th = spawn sender(&g);
    @cond_wait(g, g.ready > 0);
    u32 len = g.data;
    th.join();

    if (len != 12) { return 1; }
    return 0;
}
