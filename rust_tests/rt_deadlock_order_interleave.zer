// Rust pattern: Rust has NO deadlock detection — ZER does.
// ZER: lock ordering by type_id — ascending order is safe.
// BUG-464: lock ordering now tracks per access-group, not per function.
// write Alpha, write Beta, [gap], read Alpha, read Beta is safe —
// locks released between groups, no held-lock overlap.

shared struct Alpha { u32 x; }
shared struct Beta { u32 y; }

Alpha a;
Beta b;

u32 main() {
    // Group 1: write Alpha (lock Alpha, write, unlock)
    a.x = 10;
    // Group 2: write Beta (lock Beta, write, unlock)
    b.y = 20;

    // Group 3: read Alpha (lock Alpha, read, unlock) — no conflict,
    // Beta lock was released before this group starts.
    if (a.x != 10) { return 1; }
    // Group 4: read Beta (lock Beta, read, unlock)
    if (b.y != 20) { return 2; }

    return 0;
}
