// Rust: Condvar — loop with predicate re-check (spurious wakeup safe)
// ZER: @cond_wait loop pattern — condition rechecked automatically.
// NOTE: ZER locks PER-STATEMENT, so a multi-field/index update is not atomic
// across statements. Producers accumulate via atomic compound-assign (each
// `+=` is one locked statement) to keep the test deterministic under ZER's model.

shared struct Queue {
    u32 sum;
    u32 count;
}

Queue gq;

void enqueue(*Queue q, u32 val) {
    q.sum += val;      // atomic: compound-assign is a single locked statement
    q.count += 1;      // atomic: single locked statement
    @cond_signal(q);
}

u32 main() {
    gq.sum = 0;
    gq.count = 0;

    ThreadHandle t1 = spawn enqueue(&gq, 10);
    ThreadHandle t2 = spawn enqueue(&gq, 20);
    ThreadHandle t3 = spawn enqueue(&gq, 30);

    // Wait until three items have been enqueued
    @cond_wait(gq, gq.count >= 3);

    t1.join();
    t2.join();
    t3.join();

    if (gq.sum != 60) { return 1; }
    return 0;
}
