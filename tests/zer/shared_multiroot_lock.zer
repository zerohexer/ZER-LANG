// B1: a statement reading TWO different shared(rw) structs must lock BOTH (the
// auto-lock previously locked only the first root, leaving the second read
// unsynchronized). Read locks compose, so locking both is deadlock-free. The
// build harness checks the emitted C wraps the read in rdlock(ga)+rdlock(gb).
shared(rw) struct A { u32 v; }
shared(rw) struct B { u32 v; }
A ga;
B gb;
u32 main() {
    ga.v = 10;
    gb.v = 20;
    u32 x = ga.v + gb.v;
    if (x != 30) { return 1; }
    return 0;
}
