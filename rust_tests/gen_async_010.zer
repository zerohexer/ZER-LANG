// Async: fibonacci-like computation across yields

u32 fib_a;
u32 fib_b;
u32 fib_steps;

async void fib_task() {
    fib_a = 0;
    fib_b = 1;
    u32 i = 0;
    while (i < 6) {
        u32 next = fib_a + fib_b;
        fib_a = fib_b;
        fib_b = next;
        i += 1;
        yield;
    }
    fib_steps = i;
}

u32 main() {
    fib_a = 0;
    fib_b = 0;
    fib_steps = 0;

    _zer_async_fib_task t;
    _zer_async_fib_task_init(&t);

    for (u32 i = 0; i < 7; i += 1) {
        _zer_async_fib_task_poll(&t);
    }

    // Sequence starts from fib_a=0, fib_b=1. Each iter: next=a+b; a=b; b=next.
    //   iter1: next=1;  a=1, b=1  (fib_b=1)
    //   iter2: next=2;  a=1, b=2
    //   iter3: next=3;  a=2, b=3
    //   iter4: next=5;  a=3, b=5
    //   iter5: next=8;  a=5, b=8
    //   iter6: next=13; a=8, b=13
    // After 6 iterations: fib_b=13, fib_steps=6.
    if (fib_b != 13) { return 1; }
    if (fib_steps != 6) { return 2; }
    return 0;
}
