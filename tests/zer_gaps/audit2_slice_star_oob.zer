// AUDIT2 #12b (verify [*]T bounds check with modern syntax)
// CLAIM: CLAUDE.md asserts "[*]T bounds checked on every access".
// TEST: [*]u32 of length 5, access index 10 at runtime.
// EXPECTED: runtime trap via _zer_bounds_check.

struct Cell { u32 v; }

u32 main() {
    u8[4096] buf;
    Arena ar = Arena.over(buf[0..]);
    ?[*]Cell ms = ar.alloc_slice(Cell, 5);
    [*]Cell s = ms orelse return;

    u32 idx = 10;
    u32 r = s[idx].v;   // should trap at runtime
    if (r == 999) { return 1; }
    return 0;
}
