// Regression: for-loop expression-form init must now be TYPE-CHECKED.
// Pre-fix (2026-05-29), `for (i = 0; ...)` ran check_stmt on the init which
// fell into the silent default. Type errors in the init were never reported.
//
// Test: assignment of a string to a u32. With the fix, check_expr is now
// invoked on the init and reports a type mismatch.

u32 main() {
    u32 i = 0;
    [*]u8 s = "hello";
    for (i = s; i < 5; i += 1) {  // ← type error: cannot assign [*]u8 to u32
        i += 1;
    }
    return 0;
}
