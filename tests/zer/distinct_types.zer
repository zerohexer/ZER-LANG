// Distinct typedef wrapping all compound types
// BUG-410: checker deref + field access, emitter field/pointer dispatch
// Tests: distinct *T deref, distinct struct field, distinct *T auto-deref

struct Motor { u32 speed; bool active; }
struct Point { u32 x; u32 y; }

distinct typedef *u32 SafePtr;
distinct typedef *Motor SafeMotor;
distinct typedef Point Vec2;

u32 test_deref() {
    u32 x = 42;
    SafePtr p = @cast(SafePtr, &x);
    u32 v = *p;
    if (v != 42) { return 1; }
    return 0;
}

u32 test_struct_field() {
    Vec2 v;
    v.x = 10;
    v.y = 20;
    u32 sum = v.x + v.y;
    if (sum != 30) { return 1; }
    return 0;
}

u32 test_ptr_auto_deref() {
    Motor m;
    m.speed = 5000;
    m.active = true;
    SafeMotor sm = @cast(SafeMotor, &m);
    u32 s = sm.speed;
    if (s != 5000) { return 1; }
    if (!sm.active) { return 2; }
    return 0;
}

u32 main() {
    if (test_deref() != 0) { return 1; }
    if (test_struct_field() != 0) { return 2; }
    if (test_ptr_auto_deref() != 0) { return 3; }
    return 0;
}
