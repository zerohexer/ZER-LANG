// Rust: async fn — coroutine accumulates state across yields
// ZER: async task with accumulator, state preserved in struct
// Equivalent to: Rust async fn with persisted local state

u32 gaccum;
u32 gdone;

async void accumulate() {
    u32 total = 0;
    u32 step = 1;
    while (step <= 5) {
        total += step;
        step += 1;
        yield;
    }
    gaccum = total;
    gdone = 1;
}

u32 main() {
    gaccum = 0;
    gdone = 0;

    _zer_async_accumulate task;
    _zer_async_accumulate_init(&task);

    while (gdone == 0) {
        _zer_async_accumulate_poll(&task);
    }

    // 1+2+3+4+5 = 15
    if (gaccum != 15) { return 1; }
    return 0;
}
