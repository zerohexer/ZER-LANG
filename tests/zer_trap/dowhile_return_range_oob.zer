// audit 2026-07-06 F1: find_return_range skipped NODE_DO_WHILE bodies, so the
// return range under-approximated and buf[pick(7)] elided its bounds check.
// pick(7) returns 999 -> must TRAP at runtime (not silently read OOB).
u32 pick(u32 x) {
  u32 i = 0;
  do { if (x == 7) { return 999; } i += 1; } while (i < 3);
  return 0;
}
u32 main() {
  u8[4] buf;
  return buf[pick(7)];
}
